    replacement_infos {
      original_chunk {
        target_content: "          {/* Section 3: Interactive Sandbox (Practice) */}\n          {shortsData && (\n            <section className=\"bg-white rounded-3xl p-6 shadow-sm border border-stone-200\">\n              <div className=\"flex items-center justify-between mb-4\">\n                <div className=\"flex items-center gap-2\">\n                  <div className=\"bg-red-50 text-red-500 p-1.5 rounded-lg\">\n                    <BookOpen className=\"w-4 h-4\" />\n                  </div>\n                  <h2 className=\"text-base font-bold text-stone-800\">3\353\213\250\352\263\204. 1\353\223\261\352\270\211 \352\260\200\354\206\215 \354\234\240\354\202\254 \353\254\270\354\240\234 \355\212\270\353\240\210\354\235\264\353\213\235</h2>\n                </div>\n                <span className=\"text-xs font-bold text-emerald-600 flex items-center gap-1\">\n                  <CheckCircle className=\"w-3.5 h-3.5\" /> 100% \354\240\225\352\265\220\355\225\234 AI \354\266\234\354\240\234\n                </span>\n              </div>\n              \n              <p className=\"text-xs text-stone-500 leading-relaxed mb-4\">\n                \353\260\251\352\270\210 \353\263\270 \354\210\217\354\270\240\354\235\230 <strong>{shortsData.concept}</strong> \352\260\234\353\205\220\354\235\204 \354\231\204\353\262\275\355\236\210 \355\235\241\354\210\230\355\226\210\353\212\224\354\247\200 \352\262\200\354\246\235\355\225\264\353\263\264\354\204\270\354\232\224. \n                AI\352\260\200 \354\234\240\354\202\254\355\225\234 \353\263\200\355\230\225 \354\210\230\353\212\245 \353\254\270\354\240\234\353\245\274 \354\246\211\354\204\235 \354\266\234\354\240\234\355\225\251\353\213\210\353\213\244.\n              </p>\n\n              {!practiceQuestion ? (\n                <button\n                  type=\"button\"\n                  onClick={handleGenerateSandboxProblem}\n                  disabled={practiceIsLoading}\n                  className=\"w-full py-3.5 bg-stone-900 hover:bg-stone-800 text-white rounded-2xl text-xs font-bold flex items-center justify-center gap-2 transition-all disabled:bg-stone-400\"\n                >\n                  {practiceIsLoading ? (\n                    <>\n                      <RefreshCw className=\"w-4 h-4 animate-spin\" />\n                      <span>\354\210\230\353\212\245\352\270\211 \353\263\200\355\230\225 \353\254\270\354\240\234 \354\204\244\352\263\204 \354\244\221...</span>\n                    </>\n                  ) : (\n                    <>\n                      <Sparkles className=\"w-4 h-4 text-yellow-400\" />\n                      <span>{shortsData.concept} \354\234\240\354\202\254 \354\227\260\354\212\265 \353\254\270\354\240\234 \354\203\235\354\204\261</span>\n                    </>\n                  )}\n                </button>\n              ) : (\n                <div className=\"space-y-4 animate-fade-in bg-stone-50 p-4 rounded-2xl border border-stone-200\">\n                  <div className=\"flex items-center justify-between\">\n                    <span className=\"text-[10px] font-bold px-2 py-0.5 rounded-full bg-stone-200 text-stone-600\">\352\260\234\353\205\220: {shortsData.concept}</span>\n                    <span className=\"text-[10px] text-stone-400\">\353\202\234\354\235\264\353\217\204: {shortsData.difficulty}</span>\n                  </div>\n                  \n                  <p className=\"text-xs font-bold text-stone-800 leading-relaxed bg-white p-3 rounded-xl border border-stone-200 shadow-sm whitespace-pre-wrap\">\n                    {practiceQuestion.problem}\n                  </p>\n\n                  {/* Multiple Choice Options */}\n                  <div className=\"space-y-2\">\n                    {practiceQuestion.options.map((option: string, idx: number) => (\n                      <button\n                        key={idx}\n                        type=\"button\"\n                        disabled={hasCheckedAnswer}\n                        onClick={() => setSelectedAnswer(idx)}\n                        className={`w-full p-3 rounded-xl text-left text-xs transition-all flex items-center justify-between border ${\n                          selectedAnswer === idx\n                            ? \"bg-red-50 border-red-400 text-red-950 font-bold shadow-sm\"\n                            : \"bg-white border-stone-200 hover:bg-stone-100 text-stone-700\"\n                        }`}\n                      >\n                        <span>({idx + 1}) {option}</span>\n                        {hasCheckedAnswer && idx === practiceQuestion.correctIndex && (\n                          <CheckCircle className=\"w-4 h-4 text-emerald-500\" />\n                        )}\n                      </button>\n                    ))}\n                  </div>\n\n                  {/* Grading Actions */}\n                  <div className=\"flex gap-2 pt-2\">\n                    {!hasCheckedAnswer ? (\n                      <button\n                        type=\"button\"\n                        disabled={selectedAnswer === null}\n                        onClick={checkAnswer}\n                        className=\"flex-1 py-3 bg-red-500 hover:bg-red-600 text-white rounded-xl text-xs font-bold transition-all disabled:bg-stone-300 disabled:cursor-not-allowed\"\n                      >\n                        \354\240\225\353\213\265 \354\240\234\354\266\234 \353\260\217 \354\261\204\354\240\220\355\225\230\352\270\260\n                      </button>\n                    ) : (\n                      <div className=\"w-full space-y-3\">\n                        <div className={`p-3.5 rounded-xl text-xs flex items-center gap-2.5 ${\n                          selectedAnswer === practiceQuestion.correctIndex\n                            ? \"bg-emerald-50 border border-emerald-200 text-emerald-900\"\n                            : \"bg-red-50 border border-red-100 text-red-900\"\n                        }`}>\n                          {selectedAnswer === practiceQuestion.correctIndex ? (\n                            <>\n                              <Award className=\"w-5 h-5 text-emerald-600 animate-bounce\" />\n                              <div>\n                                <div className=\"font-extrabold\">\354\240\225\353\213\265\354\236\205\353\213\210\353\213\244! (+10\354\240\220)</div>\n                                <div className=\"text-[11px] opacity-90\">\352\260\234\353\205\220 \354\235\264\355\225\264\353\217\204\352\260\200 \354\225\204\354\243\274 \353\233\260\354\226\264\353\202\251\353\213\210\353\213\244!</div>\n                              </div>\n                            </>\n                          ) : (\n                            <>\n                              <AlertCircle className=\"w-5 h-5 text-red-600\" />\n                              <div>\n                                <div className=\"font-extrabold\">\354\230\244\353\213\265\354\236\205\353\213\210\353\213\244...</div>\n                                <div className=\"text-[11px] opacity-90\">\354\225\204\354\211\275\354\247\200\353\247\214 \355\222\200\354\235\264 \353\205\270\355\212\270\353\245\274 \352\262\200\355\206\240\355\225\264\353\263\264\354\204\270\354\232\224!</div>\n                              </div>\n                            </>\n                          )}\n                        </div>\n\n                        {/* Expandable Explanation */}\n                        <div className=\"bg-white p-3.5 rounded-xl border border-stone-200 text-xs\">\n                          <h4 className=\"font-bold text-stone-800 mb-1\">\354\203\201\354\204\270 \355\225\264\354\204\244 \353\260\217 \352\263\265\354\213\235 \353\214\200\354\236\205:</h4>\n                          <p className=\"text-[11px] text-stone-600 leading-relaxed whitespace-pre-wrap\">{practiceQuestion.explanation}</p>\n                        </div>\n\n                        <button\n                          type=\"button\"\n                          onClick={handleGenerateSandboxProblem}\n                          className=\"w-full py-2.5 border border-stone-300 hover:bg-stone-50 text-stone-700 rounded-xl text-xs font-bold flex items-center justify-center gap-1.5 transition-all\"\n                        >\n                          <RefreshCw className=\"w-3.5 h-3.5\" />\n                          \354\203\210\353\241\234\354\232\264 \354\227\260\354\212\265\353\254\270\354\240\234 \355\222\200\352\270\260\n                        </button>\n                      </div>\n                    )}\n                  </div>\n                </div>\n              )}\n            </section>\n          )}"
        replacement_content: "          {/* Section 3: Interactive Sandbox (Practice) */}\n          {shortsData && (\n            <section className=\"bg-white/5 border border-white/10 rounded-3xl p-6 backdrop-blur-xl relative shadow-2xl\">\n              <div className=\"absolute inset-0 border border-blue-500/10 rounded-3xl pointer-events-none\"></div>\n              <div className=\"flex items-center justify-between mb-4 relative z-10\">\n                <div className=\"flex items-center gap-2\">\n                  <div className=\"bg-blue-500/20 text-blue-400 p-1.5 rounded-lg border border-blue-500/20\">\n                    <BookOpen className=\"w-4 h-4\" />\n                  </div>\n                  <h2 className=\"text-base font-bold text-white font-display\">3\353\213\250\352\263\204. 1\353\223\261\352\270\211 \352\260\200\354\206\215 \354\234\240\354\202\254 \353\254\270\354\240\234 \355\212\270\353\240\210\354\235\264\353\213\235</h2>\n                </div>\n                <span className=\"text-xs font-bold text-emerald-400 flex items-center gap-1.5 font-mono\">\n                  <CheckCircle className=\"w-3.5 h-3.5\" /> AI Generator\n                </span>\n              </div>\n              \n              <p className=\"text-xs text-white/60 leading-relaxed mb-4 relative z-10\">\n                \353\260\251\352\270\210 \353\263\270 \354\210\217\354\270\240\354\235\230 <strong className=\"text-blue-400 font-medium\">{shortsData.concept}</strong> \352\260\234\353\205\220\354\235\204 \354\231\204\353\262\275\355\236\210 \355\235\241\354\210\230\355\226\210\353\212\224\354\247\200 \352\262\200\354\246\235\355\225\264\353\263\264\354\204\270\354\232\224. \n                AI\352\260\200 \354\234\240\354\202\254\355\225\234 \353\263\200\355\230\225 \354\210\230\353\212\245 \353\254\270\354\240\234\353\245\274 \354\246\211\354\204\235 \354\266\234\354\240\234\355\225\251\353\213\210\353\213\244.\n              </p>\n\n              {!practiceQuestion ? (\n                <button\n                  type=\"button\"\n                  onClick={handleGenerateSandboxProblem}\n                  disabled={practiceIsLoading}\n                  className=\"w-full py-3.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-500 hover:to-indigo-500 text-white rounded-2xl text-xs font-bold flex items-center justify-center gap-2 transition-all disabled:opacity-40 cursor-pointer shadow-lg shadow-blue-500/10 relative z-10\"\n                >\n                  {practiceIsLoading ? (\n                    <>\n                      <RefreshCw className=\"w-4 h-4 animate-spin text-blue-300\" />\n                      <span className=\"font-mono\">\354\210\230\353\212\245\352\270\211 \353\263\200\355\230\225 \353\254\270\354\240\234 \354\204\244\352\263\204 \354\244\221...</span>\n                    </>\n                  ) : (\n                    <>\n                      <Sparkles className=\"w-4 h-4 text-yellow-300\" />\n                      <span>{shortsData.concept} \354\234\240\354\202\254 \354\227\260\354\212\265 \353\254\270\354\240\234 \354\203\235\354\204\261</span>\n                    </>\n                  )}\n                </button>\n              ) : (\n                <div className=\"space-y-4 animate-fade-in bg-black/40 p-4 rounded-2xl border border-white/10 relative z-10\">\n                  <div className=\"flex items-center justify-between\">\n                    <span className=\"text-[10px] font-bold px-2 py-0.5 rounded-full bg-white/10 text-blue-300 border border-white/5 font-mono\">\352\260\234\353\205\220: {shortsData.concept}</span>\n                    <span className=\"text-[10px] text-white/40 font-mono\">\353\202\234\354\235\264\353\217\204: {shortsData.difficulty}</span>\n                  </div>\n                  \n                  <p className=\"text-xs font-bold text-white leading-relaxed bg-white/5 p-4 rounded-xl border border-white/5 shadow-inner whitespace-pre-wrap font-mono\">\n                    {practiceQuestion.problem}\n                  </p>\n\n                  {/* Multiple Choice Options */}\n                  <div className=\"space-y-2\">\n                    {practiceQuestion.options.map((option: string, idx: number) => (\n                      <button\n                        key={idx}\n                        type=\"button\"\n                        disabled={hasCheckedAnswer}\n                        onClick={() => setSelectedAnswer(idx)}\n                        className={`w-full p-3.5 rounded-xl text-left text-xs transition-all flex items-center justify-between border cursor-pointer ${\n                          selectedAnswer === idx\n                            ? \"bg-blue-500/15 border-blue-500/50 text-white font-bold shadow-md shadow-blue-500/5\"\n                            : \"bg-white/5 border-white/10 hover:bg-white/10 text-white/70\"\n                        }`}\n                      >\n                        <span>({idx + 1}) {option}</span>\n                        {hasCheckedAnswer && idx === practiceQuestion.correctIndex && (\n                          <CheckCircle className=\"w-4 h-4 text-emerald-400\" />\n                        )}\n                      </button>\n                    ))}\n                  </div>\n\n                  {/* Grading Actions */}\n                  <div className=\"flex gap-2 pt-2\">\n                    {!hasCheckedAnswer ? (\n                      <button\n                        type=\"button\"\n                        disabled={selectedAnswer === null}\n                        onClick={checkAnswer}\n                        className=\"flex-1 py-3 bg-gradient-to-r from-blue-500 to-indigo-600 hover:opacity-95 text-white rounded-xl text-xs font-bold transition-all disabled:opacity-30 disabled:cursor-not-allowed cursor-pointer shadow-md shadow-blue-500/10\"\n                      >\n                        \354\240\225\353\213\265 \354\240\234\354\266\234 \353\260\217 \354\261\204\354\240\220\355\225\230\352\270\260\n                      </button>\n                    ) : (\n                      <div className=\"w-full space-y-3\">\n                        <div className={`p-4 rounded-xl text-xs flex items-center gap-3 border ${\n                          selectedAnswer === practiceQuestion.correctIndex\n                            ? \"bg-emerald-500/10 border-emerald-500/30 text-emerald-300\"\n                            : \"bg-red-500/10 border-red-500/30 text-red-300\"\n                        }`}>\n                          {selectedAnswer === practiceQuestion.correctIndex ? (\n                            <>\n                              <Award className=\"w-5 h-5 text-emerald-400 animate-bounce\" />\n                              <div>\n                                <div className=\"font-extrabold\">\354\240\225\353\213\265\354\236\205\353\213\210\353\213\244! (+10\354\240\220)</div>\n                                <div className=\"text-[11px] opacity-90\">\352\260\234\353\205\220 \354\235\264\355\225\264\353\217\204\352\260\200 \354\225\204\354\243\274 \353\233\260\354\226\264\353\202\251\353\213\210\353\213\244!</div>\n                              </div>\n                            </>\n                          ) : (\n                            <>\n                              <AlertCircle className=\"w-5 h-5 text-red-400\" />\n                              <div>\n                                <div className=\"font-extrabold\">\354\230\244\353\213\265\354\236\205\353\213\210\353\213\244...</div>\n                                <div className=\"text-[11px] opacity-90\">\354\225\204\354\211\275\354\247\200\353\247\214 \355\222\200\354\235\264 \353\205\270\355\212\270\353\245\274 \352\262\200\355\206\240\355\225\264\353\263\264\354\204\270\354\232\224!</div>\n                              </div>\n                            </>\n                          )}\n                        </div>\n\n                        {/* Expandable Explanation */}\n                        <div className=\"bg-white/5 p-4 rounded-xl border border-white/10 text-xs\">\n                          <h4 className=\"font-bold text-blue-400 mb-1.5 uppercase tracking-wider text-[10px]\">\354\203\201\354\204\270 \355\225\264\354\204\244 \353\260\217 \352\263\265\354\213\235 \353\214\200\354\236\205:</h4>\n                          <p className=\"text-[11px] text-white/75 leading-relaxed whitespace-pre-wrap font-mono\">{practiceQuestion.explanation}</p>\n                        </div>\n\n                        <button\n                          type=\"button\"\n                          onClick={handleGenerateSandboxProblem}\n                          className=\"w-full py-2.5 bg-white/10 border border-white/10 hover:bg-white/15 text-white rounded-xl text-xs font-bold flex items-center justify-center gap-1.5 transition-all cursor-pointer\"\n                        >\n                          <RefreshCw className=\"w-3.5 h-3.5\" />\n                          \354\203\210\353\241\234\354\232\264 \354\227\260\354\212\265\353\254\270\354\240\234 \355\222\200\352\270\260\n                        </button>\n                      </div>\n                    )}\n                  </div>\n                </div>\n              )}\n            </section>\n          )}"
      }
