ass=\\\"text-[10px] text-purple-300 font-mono\\\">Step 02: Critical Points</p>\\n                  <p class=\\\"text-xs\\\">x = 0 (Inflection Point)</p>\\n                </div>\\n              </div>\\n            </div>\\n\\n            <!-- Shorts UI Elements -->\\n            <div class=\\\"absolute bottom-8 left-4 right-4 flex items-end justify-between\\\">\\n              <div class=\\\"flex-1\\\">\\n                <div class=\\\"flex items-center gap-2 mb-3\\\">\\n                  <div class=\\\"w-8 h-8 rounded-full bg-blue-500\\\"></div>\\n                  <p class=\\\"text-xs font-bold\\\">@MathShortsAI</p>\\n                  <button class=\\\"px-2 py-0.5 bg-red-600 rounded text-[9px] font-bold uppercase\\\">Follow</button>\\n                </div>\\n                <p class=\\\"text-[10px] leading-relaxed text-white/80\\\">\\n                  2024 \354\210\230\353\212\245 \354\210\230\355\225\231 30\353\262\210 \355\202\254\353\237\254\353\254\270\355\225\255 60\354\264\210 \355\222\200\354\235\264 \360\237\224\245 #\354\210\230\353\212\245 #\354\210\230\355\225\231 #\353\257\270\354\240\201\353\266\204\\n                </p>\\n              </div>\\n              <div class=\\\"flex flex-col gap-5 items-center pb-2\\\">\\n                <div class=\\\"flex flex-col items-center gap-1\\\"><div class=\\\"w-5 h-5 bg-white/20 rounded\\\"></div><span class=\\\"text-[8px]\\\">12.4k</span></div>\\n                <div class=\\\"flex flex-col items-center gap-1\\\"><div class=\\\"w-5 h-5 bg-white/20 rounded\\\"></div><span class=\\\"text-[8px]\\\">342</span></div>\\n                <div class=\\\"flex flex-col items-center gap-1\\\"><div class=\\\"w-5 h-5 bg-white/20 rounded\\\"></div><span class=\\\"text-[8px]\\\">Share</span></div>\\n              </div>\\n            </div>\\n          </div>\\n          \\n          <!-- Notch -->\\n          <div class=\\\"absolute top-0 left-1/2 -translate-x-1/2 w-32 h-6 bg-[#222] rounded-b-2xl\\\"></div>\\n        </