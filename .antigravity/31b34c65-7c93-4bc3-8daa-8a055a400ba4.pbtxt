      replacement_content: "  // Helper to split text by accentWords for stylized subtitle effects\n  const renderHighlightedExplanation = (explanation: string, accentWords: string[]) => {\n    if (!accentWords || accentWords.length === 0) return <span>{explanation}</span>;\n    \n    // Escape regex characters\n    const escapedWords = accentWords.map(w => w.replace(/[-\\/\\\\^$*+?.()|[\\]{}]/g, \"\\\\$&\"));\n    const regex = new RegExp(`(${escapedWords.join(\"|\")})`, \"g\");\n    const parts = explanation.split(regex);\n    \n    return parts.map((part, index) => {\n      const isAccent = accentWords.some(accent => accent.toLowerCase() === part.toLowerCase());\n      return isAccent ? (\n        <motion.span\n          key={index}\n          className={`${themeStyles.accentTextClass} inline-block mx-1`}\n          animate={{ scale: [1, 1.1, 1] }}\n          transition={{ repeat: Infinity, duration: 2, delay: index * 0.2 }}\n        >\n          {part}\n        </motion.span>\n      ) : (\n        <span key={index}>{part}</span>\n      );\n    });\n  };\n\n  return (\n    <div className=\"min-h-screen bg-[#050505] text-white flex flex-col font-sans transition-all relative overflow-x-hidden\">\n      \n      {/* Atmospheric Background Glows */}\n      <div className=\"absolute top-[-10%] left-[-10%] w-[50%] h-[50%] bg-blue-600/15 rounded-full blur-[140px] pointer-events-none z-0\"></div>\n      <div className=\"absolute bottom-[-10%] right-[-10%] w-[50%] h-[50%] bg-purple-600/15 rounded-full blur-[140px] pointer-events-none z-0\"></div>\n\n      {/* Top Immersive Header */}\n      <header className=\"relative z-50 flex items-center justify-between py-4 px-6 sm:px-8 border-b border-white/10 backdrop-blur-md bg-black/40 sticky top-0\">\n        <div className=\"max-w-7xl w-full mx-auto flex flex-col sm:flex-row items-center justify-between gap-4\">\n          <div className=\"flex items-center gap-3\">\n            <div className=\"w-10 h-10 bg-gradient-to-br from-blue-500 to-purple-600 rounded-xl flex items-center justify-center shadow-lg shadow-blue-500/20\">\n              <Smartphone className=\"w-5 h-5 text-white\" id=\"app-logo-icon\" />\n            </div>\n            <div>\n              <div className=\"flex items-center gap-2\">\n                <h1 className=\"text-xl font-bold tracking-tight text-white font-display\">\354\210\230\353\212\245 \354\210\230\355\225\231 <span className=\"text-blue-400\">SHORTS</span> AI</h1>\n                <span className=\"bg-blue-500/20 text-blue-300 border border-blue-500/30 text-[9px] font-bold px-2 py-0.5 rounded-full uppercase tracking-wider\">v2.0 Engine</span>\n              </div>\n              <p className=\"text-[10px] text-white/40 uppercase tracking-[0.15em]\">Suneung Solver Engine \342\200\242 Realtime Synthesis</p>\n            </div>\n          </div>\n          \n          <div className=\"flex items-center gap-4\">\n            <div className=\"bg-white/5 border border-white/10 rounded-xl px-4 py-1.5 flex items-center gap-2.5 backdrop-blur-sm\">\n              <Award className=\"w-4 h-4 text-yellow-400\" />\n              <div className=\"text-right\">\n                <div className=\"text-[9px] text-white/40 font-semibold uppercase leading-none tracking-wider\">\354\230\244\353\212\230\354\235\230 \354\235\270\354\246\235 \354\240\220\354\210\230</div>\n                <div className=\"text-xs font-bold text-white\">\354\210\230\355\225\231 \354\213\244\353\240\245: <span className=\"text-blue-400 font-mono\">{sandboxScore}\354\240\220</span></div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </header>"
