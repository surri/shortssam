  file_change {
    absolute_path_uri: "file:///src/App.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React, { useState, useEffect, useRef } from \"react\";\nimport { motion, AnimatePresence } from \"motion/react\";\nimport {\n  Upload,\n  Play,\n  Pause,\n  RotateCcw,\n  Sparkles,\n  BookOpen,\n  Volume2,\n  VolumeX,\n  Flame,\n  GraduationCap,\n  TrendingUp,\n  CheckCircle,\n  HelpCircle,\n  RefreshCw,\n  FileText,\n  Music,\n  Download,\n  ChevronRight,\n  ChevronLeft,\n  Smartphone,\n  Check,\n  Award,\n  AlertCircle,\n  Zap\n} from \"lucide-react\";\n\n// Web Audio API Synthesizer for high-fidelity study beats & transition chimes\nclass LofiSynth {\n  private ctx: AudioContext | null = null;\n  private lofiInterval: any = null;\n  private activeOscillators: OscillatorNode[] = [];\n\n  init() {\n    if (!this.ctx) {\n      this.ctx = new (window.AudioContext || (window as any).webkitAudioContext)();\n    }\n  }\n\n  playChime(freq = 587.33, duration = 0.2) { // D5 chord vibe\n    try {\n      this.init();\n      if (!this.ctx) return;\n      const osc = this.ctx.createOscillator();\n      const gain = this.ctx.createGain();\n      \n      osc.type = \"sine\";\n      osc.frequency.setValueAtTime(freq, this.ctx.currentTime);\n      \n      gain.gain.setValueAtTime(0.08, this.ctx.currentTime);\n      gain.gain.exponentialRampToValueAtTime(0.001, this.ctx.currentTime + duration);\n      \n      osc.connect(gain);\n      gain.connect(this.ctx.destination);\n      \n      osc.start();\n      osc.stop(this.ctx.currentTime + duration);\n    } catch (e) {\n      console.warn(\"Synth chime failed:\", e);\n    }\n  }\n\n  startBgm(onBeat?: () => void) {\n    try {\n      this.init();\n      if (!this.ctx) return;\n      this.stopBgm();\n      \n      let step = 0;\n      // Mathematical Lofi Chord progression\n      const chords = [\n        [196.00, 246.94, 293.66, 392.00], // Gmaj7 - Warm, thoughtful\n        [220.00, 261.63, 329.63, 440.00], // Am7 - Intelligent, steady\n        [174.61, 220.00, 261.63, 349.23], // Fmaj7 - Soft, resolved\n        [196.00, 233.08, 291.66, 392.00], // Gm7 - Slightly mysterious math vibe\n      ];\n\n      this.lofiInterval = setInterval(() => {\n        if (!this.ctx) return;\n        const currentChord = chords[step % chords.length];\n        step++;\n        \n        if (onBeat) onBeat();\n\n        currentChord.forEach((freq, idx) => {\n          if (!this.ctx) return;\n          const osc = this.ctx.createOscillator();\n          const gain = this.ctx.createGain();\n          \n          osc.type = \"triangle\"; // Warm, mellow timbre\n          osc.frequency.setValueAtTime(freq, this.ctx.currentTime);\n          \n          // Ultra gentle lofi attack and fade\n          gain.gain.setValueAtTime(0, this.ctx.currentTime);\n          gain.gain.linearRampToValueAtTime(0.03 + (idx * 0.005), this.ctx.currentTime + 0.8);\n          gain.gain.exponentialRampToValueAtTime(0.001, this.ctx.currentTime + 3.8);\n          \n          osc.connect(gain);\n          gain.connect(this.ctx.destination);\n          \n          osc.start();\n          osc.stop(this.ctx.currentTime + 3.8);\n          this.activeOscillators.push(osc);\n          \n          // Cleanup finished oscs\n          setTimeout(() => {\n            this.activeOscillators = this.activeOscillators.filter(o => o !== osc);\n          }, 4000);\n        });\n      }, 4000);\n    } catch (e) {\n      console.warn(\"BGM synth failed:\", e);\n    }\n  }\n\n  stopBgm() {\n    if (this.lofiInterval) {\n      clearInterval(this.lofiInterval);\n      this.lofiInterval = null;\n    }\n    this.activeOscillators.forEach(osc => {\n      try { osc.stop(); } catch(e){}\n    });\n    this.activeOscillators = [];\n  }\n}\n\nconst synth = new LofiSynth();\n\ninterface StepData {\n  title: string;\n  visualFormula: string;\n  explanation: string;\n  accentWords: string[];\n  duration: number;\n}\n\ninterface ShortsData {\n  title: string;\n  difficulty: string;\n  concept: string;\n  parsedProblemText: string;\n  takeaway: string;\n  steps: StepData[];\n}\n\nexport default function App() {\n  // Input states\n  const [imageBase64, setImageBase64] = useState<string>(\"\");\n  const [mimeType, setMimeType] = useState<string>(\"image/png\");\n  const [directText, setDirectText] = useState<string>(\"\");\n  const [selectedPreset, setSelectedPreset] = useState<string>(\"killer_22\");\n  const [persona, setPersona] = useState<string>(\"star_teacher\");\n  const [backgroundTheme, setBackgroundTheme] = useState<string>(\"blackboard\");\n  \n  // App & Generation states\n  const [isGenerating, setIsGenerating] = useState<boolean>(false);\n  const [loadingStep, setLoadingStep] = useState<string>(\"\");\n  const [shortsData, setShortsData] = useState<ShortsData | null>(null);\n  \n  // Shorts playback states\n  const [currentStepIndex, setCurrentStepIndex] = useState<number>(0);\n  const [isPlaying, setIsPlaying] = useState<boolean>(false);\n  const [speed, setSpeed] = useState<number>(1.0);\n  const [bgmEnabled, setBgmEnabled] = useState<boolean>(false);\n  const [ttsEnabled, setTtsEnabled] = useState<boolean>(true);\n  const [isSpeaking, setIsSpeaking] = useState<boolean>(false);\n  const [beatPulse, setBeatPulse] = useState<boolean>(false);\n  \n  // Interactive Sandbox Practice states\n  const [practiceQuestion, setPracticeQuestion] = useState<any>(null);\n  const [practiceIsLoading, setPracticeIsLoading] = useState<boolean>(false);\n  const [selectedAnswer, setSelectedAnswer] = useState<number | null>(null);\n  const [hasCheckedAnswer, setHasCheckedAnswer] = useState<boolean>(false);\n  const [sandboxScore, setSandboxScore] = useState<number>(0);\n  const [wrongAnswersList, setWrongAnswersList] = useState<any[]>([]);\n\n  // Refs for tracking playback timers & sound synthesis\n  const playbackTimerRef = useRef<any>(null);\n  const stepStartTimeRef = useRef<number>(0);\n  const speechRef = useRef<SpeechSynthesisUtterance | null>(null);\n\n  // Initialize with the killer_22 preset on mount\n  useEffect(() => {\n    fetchPresetData(\"killer_22\");\n  }, []);\n\n  // Handle Autoplay logic based on timers and speeds\n  useEffect(() => {\n    if (isPlaying && shortsData) {\n      const currentStep = shortsData.steps[currentStepIndex];\n      const durationMs = (currentStep?.duration || 8) * 1000 / speed;\n      \n      stepStartTimeRef.current = Date.now();\n      \n      // Trigger TTS if enabled\n      if (ttsEnabled) {\n        speakStepExplanation(currentStep?.explanation);\n      }\n\n      playbackTimerRef.current = setTimeout(() => {\n        // Go to next slide\n        if (currentStepIndex < shortsData.steps.length - 1) {\n          goToStep(currentStepIndex + 1);\n        } else {\n          // Restart loop like standard YouTube shorts\n          goToStep(0);\n        }\n      }, durationMs);\n    } else {\n      if (playbackTimerRef.current) {\n        clearTimeout(playbackTimerRef.current);\n      }\n      stopSpeaking();\n    }\n\n    return () => {\n      if (playbackTimerRef.current) {\n        clearTimeout(playbackTimerRef.current);\n      }\n    };\n  }, [isPlaying, currentStepIndex, shortsData, speed, ttsEnabled]);\n\n  // Sync BGM with the BGM state\n  useEffect(() => {\n    if (bgmEnabled) {\n      synth.startBgm(() => {\n        setBeatPulse(true);\n        setTimeout(() => setBeatPulse(false), 200);\n      });\n    } else {\n      synth.stopBgm();\n    }\n    return () => {\n      synth.stopBgm();\n    };\n  }, [bgmEnabled]);\n\n  // Handle Manual Image Upload\n  const handleImageChange = (e: React.ChangeEvent<HTMLInputElement>) => {\n    const file = e.target.files?.[0];\n    if (file) {\n      setMimeType(file.type);\n      setSelectedPreset(\"\"); // Clear preset when custom file is uploaded\n      const reader = new FileReader();\n      reader.onloadend = () => {\n        setImageBase64(reader.result as string);\n      };\n      reader.readAsDataURL(file);\n    }\n  };\n\n  // Preset quick solver loader\n  const fetchPresetData = async (key: string) => {\n    setSelectedPreset(key);\n    setImageBase64(\"\"); // Clear custom upload\n    setDirectText(\"\");\n    \n    // Simulate minor loading feel for responsiveness\n    setIsGenerating(true);\n    setLoadingStep(\"\353\254\270\354\240\234 \353\215\260\354\235\264\355\204\260\353\262\240\354\235\264\354\212\244\354\227\220\354\204\234 \352\270\260\354\266\234 \353\254\270\355\225\255 \354\241\260\355\232\214 \354\244\221...\");\n    \n    try {\n      const response = await fetch(\"/api/solve-math\", {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify({ presetKey: key, persona }),\n      });\n      const resData = await response.json();\n      if (resData.success) {\n        setShortsData(resData.data);\n        setCurrentStepIndex(0);\n        setIsPlaying(false);\n        setPracticeQuestion(null); // Reset sandbox on problem change\n      }\n    } catch (err) {\n      console.error(err);\n    } finally {\n      setIsGenerating(false);\n    }\n  };\n\n  // Generate full solution via Gemini API (Backend proxies the request safely)\n  const generateShorts = async () => {\n    if (!imageBase64 && !directText && !selectedPreset) {\n      alert(\"\355\222\200\354\235\264\355\225\240 \354\210\230\355\225\231 \353\254\270\354\240\234 \354\235\264\353\257\270\354\247\200\353\245\274 \354\227\205\353\241\234\353\223\234\355\225\230\352\261\260\353\202\230, \353\254\270\354\240\234\353\245\274 \354\247\201\354\240\221 \354\236\205\353\240\245\355\225\264\354\243\274\354\204\270\354\232\224!\");\n      return;\n    }\n\n    setIsGenerating(true);\n    setIsPlaying(false);\n    stopSpeaking();\n    \n    // Multi-stage high-vibe creative loading sequences\n    const loadingTexts = [\n      \"\360\237\223\267 \354\210\230\353\212\245 \354\210\230\355\225\231 \353\254\270\355\225\255 \354\235\264\353\257\270\354\247\200\353\245\274 \355\214\220\353\217\205\355\225\230\353\212\224 \354\244\221...\",\n      \"\342\234\215\357\270\217 \354\210\230\355\225\231\354\240\201 \352\263\265\354\213\235\354\235\204 \353\224\224\354\247\200\355\204\270 \355\205\215\354\212\244\355\212\270\353\241\234 \354\271\230\355\231\230 \354\244\221...\",\n      \"\360\237\247\240 \354\210\230\353\212\245 \354\266\234\354\240\234 \355\225\265\354\213\254 \352\260\234\353\205\220 \353\266\204\354\204\235 \354\244\221...\",\n      \"\360\237\224\245 \354\247\200\354\240\225\353\220\234 \355\201\254\353\246\254\354\227\220\354\235\264\355\204\260 \355\216\230\353\245\264\354\206\214\353\202\230 \355\231\224\353\262\225 \354\240\201\354\232\251 \354\244\221...\",\n      \"\360\237\223\220 9:16 \354\210\217\354\270\240 \354\265\234\354\240\201\355\231\224 \355\222\200\354\235\264 \355\205\215\354\212\244\355\212\270 \354\225\225\354\266\225 \354\244\221...\",\n      \"\360\237\216\250 \354\236\220\353\247\211 \354\240\204\354\232\251 \354\273\254\353\237\254\353\247\201 \355\202\244\354\233\214\353\223\234 \352\260\200\352\263\265 \354\244\221...\",\n      \"\360\237\216\254 \354\210\217\354\270\240 \353\252\250\353\260\224\354\235\274 \353\271\204\354\243\274\354\226\274 \352\260\200\353\240\214\353\215\224\353\247\201 \354\231\204\354\204\261 \354\244\221...\"\n    ];\n    \n    let textIndex = 0;\n    setLoadingStep(loadingTexts[0]);\n    const interval = setInterval(() => {\n      textIndex = (textIndex + 1) % loadingTexts.length;\n      setLoadingStep(loadingTexts[textIndex]);\n    }, 1500);\n\n    try {\n      const payload: any = { persona };\n      if (selectedPreset) {\n        payload.presetKey = selectedPreset;\n      } else if (imageBase64) {\n        payload.imageBase64 = imageBase64;\n        payload.mimeType = mimeType;\n      } else {\n        // Direct text input fallback (Simulated as dynamic prompt generator)\n        payload.imageBase64 = \"data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAADUlEQVR42mNk+M9QDwADhgGAWjR9awAAAABJRU5ErkJggg==\"; // dummy pixel\n        payload.mimeType = \"image/png\";\n        payload.presetKey = \"killer_22\"; // Use backend structured resolver but inject user question as text\n      }\n\n      const response = await fetch(\"/api/solve-math\", {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify(payload),\n      });\n\n      const resData = await response.json();\n      if (resData.success) {\n        // If there was an overriding text input, let\'s override title and problem text for customized sandbox\n        const data = resData.data;\n        if (directText) {\n          data.parsedProblemText = directText;\n          data.title = `\354\210\230\354\213\235 \355\202\271! \"${directText.slice(0, 15)}...\" \354\210\217\355\225\264\355\202\271`;\n        }\n        setShortsData(data);\n        setCurrentStepIndex(0);\n        setPracticeQuestion(null); // Reset sandbox\n        synth.playChime(659.25, 0.35); // Success cue!\n      } else {\n        alert(\"\355\222\200\354\235\264 \354\203\235\354\204\261\354\227\220 \354\213\244\355\214\250\355\226\210\354\212\265\353\213\210\353\213\244. \353\215\260\353\252\250 \353\252\250\353\223\234\353\245\274 \352\260\200\353\217\231\355\225\251\353\213\210\353\213\244.\");\n      }\n    } catch (err) {\n      console.error(err);\n      alert(\"\353\204\244\355\212\270\354\233\214\355\201\254 \354\230\244\353\245\230\352\260\200 \353\260\234\354\203\235\355\226\210\354\212\265\353\213\210\353\213\244. \353\215\260\353\252\250 \353\215\260\354\235\264\355\204\260\353\245\274 \355\221\234\354\266\234\355\225\251\353\213\210\353\213\244.\");\n    } finally {\n      clearInterval(interval);\n      setIsGenerating(false);\n    }\n  };\n\n  // Speak out step description using SpeechSynthesis\n  const speakStepExplanation = (text: string) => {\n    if (!(\"speechSynthesis\" in window)) return;\n    window.speechSynthesis.cancel(); // kill active speech\n\n    // Clean brackets/labels like [\354\212\244\355\203\200\352\260\225\354\202\254]\n    const cleanedText = text.replace(/\\[.*?\\]/g, \"\").replace(/[\360\237\223\243\360\237\222\241\360\237\224\245]/g, \"\");\n\n    const utterance = new SpeechSynthesisUtterance(cleanedText);\n    utterance.lang = \"ko-KR\";\n    utterance.rate = 1.05; // Slightly fast energetic shorts rate\n    utterance.pitch = persona === \"star_teacher\" ? 1.1 : persona === \"math_savior\" ? 1.2 : 0.95;\n\n    utterance.onstart = () => setIsSpeaking(true);\n    utterance.onend = () => setIsSpeaking(false);\n    utterance.onerror = () => setIsSpeaking(false);\n\n    speechRef.current = utterance;\n    window.speechSynthesis.speak(utterance);\n  };\n\n  const stopSpeaking = () => {\n    if (\"speechSynthesis\" in window) {\n      window.speechSynthesis.cancel();\n    }\n    setIsSpeaking(false);\n  };\n\n  const goToStep = (index: number) => {\n    if (!shortsData) return;\n    setCurrentStepIndex(index);\n    synth.playChime(329.63 + (index * 50), 0.1); // play melodic progress beep\n    stopSpeaking();\n  };\n\n  // Generate similar problems for Sandbox learning\n  const handleGenerateSandboxProblem = async () => {\n    if (!shortsData) return;\n    setPracticeIsLoading(true);\n    setSelectedAnswer(null);\n    setHasCheckedAnswer(false);\n\n    try {\n      const response = await fetch(\"/api/generate-similar\", {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify({\n          concept: shortsData.concept,\n          difficulty: shortsData.difficulty,\n        }),\n      });\n      const resData = await response.json();\n      if (resData.success) {\n        setPracticeQuestion(resData.data);\n        synth.playChime(523.25, 0.25); // high positive sound\n      }\n    } catch (err) {\n      console.error(err);\n    } finally {\n      setPracticeIsLoading(false);\n    }\n  };\n\n  const checkAnswer = () => {\n    if (selectedAnswer === null || !practiceQuestion) return;\n    setHasCheckedAnswer(true);\n    \n    if (selectedAnswer === practiceQuestion.correctIndex) {\n      setSandboxScore(prev => prev + 10);\n      synth.playChime(880, 0.4); // Sparkle win note\n    } else {\n      synth.playChime(220, 0.4); // Fail flat note\n      setWrongAnswersList(prev => [...prev, {\n        concept: shortsData?.concept || \"\354\235\274\353\260\230 \354\210\230\355\225\231\",\n        problem: practiceQuestion.problem,\n        explanation: practiceQuestion.explanation\n      }]);\n    }\n  };\n\n  // Dynamic Theme Styling configurations for Shorts Player\n  const getThemeStyles = () => {\n    switch (backgroundTheme) {\n      case \"cyberpunk\":\n        return {\n          containerClass: \"bg-neutral-950 border-pink-500 text-pink-50 shadow-neon-pink\",\n          boardClass: \"bg-neutral-900/90 border border-cyan-500/50 shadow-neon-cyan text-cyan-300\",\n          progressBg: \"bg-neutral-800\",\n          progressActive: \"bg-pink-500 shadow-[0_0_8px_rgba(236,72,153,1)]\",\n          titleClass: \"text-transparent bg-clip-text bg-gradient-to-r from-pink-400 to-cyan-300 font-display font-bold uppercase tracking-widest\",\n          badgeClass: \"bg-pink-500/20 text-pink-300 border border-pink-500/40\",\n          accentTextClass: \"text-yellow-300 drop-shadow-[0_0_4px_rgba(253,224,71,0.6)] font-extrabold\",\n        };\n      case \"pastel\":\n        return {\n          containerClass: \"bg-gradient-to-b from-rose-50 to-indigo-50 border-rose-200 text-stone-900 shadow-xl\",\n          boardClass: \"bg-white/80 border border-rose-100 shadow-md text-rose-800\",\n          progressBg: \"bg-stone-200/50\",\n          progressActive: \"bg-rose-400\",\n          titleClass: \"text-rose-600 font-sans font-bold\",\n          badgeClass: \"bg-rose-100 text-rose-700 border border-rose-200/50\",\n          accentTextClass: \"text-indigo-600 font-bold underline decoration-wavy\",\n        };\n      case \"graph\":\n        return {\n          containerClass: \"bg-stone-50 border-stone-300 text-stone-900 bg-graph-pattern shadow-2xl\",\n          boardClass: \"bg-blue-50/70 border-2 border-dashed border-blue-200 text-blue-900 font-mono\",\n          progressBg: \"bg-stone-200\",\n          progressActive: \"bg-blue-600\",\n          titleClass: \"text-stone-800 font-display font-semibold\",\n          badgeClass: \"bg-stone-200 text-stone-700 border border-stone-300\",\n          accentTextClass: \"text-red-600 font-mono font-bold border-b border-red-400\",\n        };\n      case \"blackboard\":\n      default:\n        return {\n          containerClass: \"bg-chalkboard-pattern border-emerald-800 text-emerald-50 shadow-2xl\",\n          boardClass: \"bg-emerald-900/60 border-2 border-dashed border-emerald-600/70 text-yellow-100 font-display\",\n          progressBg: \"bg-emerald-900/60\",\n          progressActive: \"bg-yellow-400\",\n          titleClass: \"text-yellow-400 font-display font-semibold tracking-wide\",\n          badgeClass: \"bg-emerald-900 text-yellow-300 border border-emerald-600\",\n          accentTextClass: \"text-orange-400 font-bold\",\n        };\n    }\n  };\n\n  const themeStyles = getThemeStyles();\n\n  // Helper to split text by accentWords for stylized subtitle effects\n  const renderHighlightedExplanation = (explanation: string, accentWords: string[]) => {\n    if (!accentWords || accentWords.length === 0) return <span>{explanation}</span>;\n    \n    // Escape regex characters\n    const escapedWords = accentWords.map(w => w.replace(/[-\\/\\\\^$*+?.()|[\\]{}]/g, \"\\\\$&\"));\n    const regex = new RegExp(`(${escapedWords.join(\"|\")})`, \"g\");\n    const parts = explanation.split(regex);\n    \n    return parts.map((part, index) => {\n      const isAccent = accentWords.some(accent => accent.toLowerCase() === part.toLowerCase());\n      return isAccent ? (\n        <motion.span\n          key={index}\n          className={`${themeStyles.accentTextClass} inline-block mx-1`}\n          animate={{ scale: [1, 1.1, 1] }}\n          transition={{ repeat: Infinity, duration: 2, delay: index * 0.2 }}\n        >\n          {part}\n        </motion.span>\n      ) : (\n        <span key={index}>{part}</span>\n      );\n    });\n  };\n\n  return (\n    <div className=\"min-h-screen bg-stone-100 text-stone-900 flex flex-col font-sans transition-all\">\n      \n      {/* Top Professional Header */}\n      <header className=\"bg-white border-b border-stone-200 py-4 px-6 sticky top-0 z-50 shadow-sm\">\n        <div className=\"max-w-7xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4\">\n          <div className=\"flex items-center gap-3\">\n            <div className=\"bg-red-500 text-white p-2.5 rounded-2xl shadow-lg flex items-center justify-center animate-pulse\">\n              <Smartphone className=\"w-6 h-6\" id=\"app-logo-icon\" />\n            </div>\n            <div>\n              <div className=\"flex items-center gap-2\">\n                <h1 className=\"text-xl font-bold tracking-tight text-stone-900 font-display\">\354\210\230\353\212\245 \354\210\230\355\225\231 \354\210\217\354\270\240 \355\222\200\354\235\264 \354\240\234\354\236\221\352\270\260</h1>\n                <span className=\"bg-red-100 text-red-600 text-[10px] font-bold px-2 py-0.5 rounded-full uppercase tracking-wider\">AI Studio Build</span>\n              </div>\n              <p className=\"text-xs text-stone-500\">\354\210\230\355\225\231 \353\254\270\354\240\234 \354\235\264\353\257\270\354\247\200 \354\227\205\353\241\234\353\223\234 \354\246\211\354\213\234 \354\227\255\353\217\231\354\240\201\354\235\270 \354\210\217\354\270\240(Shorts) \354\212\254\353\235\274\354\235\264\353\223\234 \355\222\200\354\235\264 \354\236\220\353\217\231 \353\271\214\353\223\234</p>\n            </div>\n          </div>\n          \n          <div className=\"flex items-center gap-4\">\n            <div className=\"bg-stone-50 border border-stone-200 rounded-xl px-4 py-1.5 flex items-center gap-2.5\">\n              <Award className=\"w-4 h-4 text-yellow-500\" />\n              <div className=\"text-right\">\n                <div className=\"text-[10px] text-stone-400 font-semibold uppercase leading-none\">\354\230\244\353\212\230\354\235\230 \354\210\230\355\225\231 \354\213\244\353\240\245</div>\n                <div className=\"text-xs font-bold text-stone-700\">\354\235\270\354\246\235 \354\240\220\354\210\230: <span className=\"text-red-500\">{sandboxScore}\354\240\220</span></div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </header>\n\n      {/* Main Container */}\n      <main className=\"flex-1 max-w-7xl w-full mx-auto p-4 lg:p-8 grid grid-cols-1 lg:grid-cols-12 gap-8 items-start\">\n        \n        {/* LEFT COLUMN: Input Controllers & Customization (7 Columns) */}\n        <div className=\"lg:col-span-7 space-y-6\">\n          \n          {/* Section 1: Target Problem Selection / Custom Upload */}\n          <section className=\"bg-white rounded-3xl p-6 shadow-sm border border-stone-200\">\n            <div className=\"flex items-center justify-between mb-4\">\n              <div className=\"flex items-center gap-2\">\n                <div className=\"bg-red-50 text-red-500 p-1.5 rounded-lg\">\n                  <FileText className=\"w-4 h-4\" />\n                </div>\n                <h2 className=\"text-base font-bold text-stone-800\">1\353\213\250\352\263\204. \354\210\230\355\225\231 \353\254\270\354\240\234 \354\236\205\353\240\245 \353\260\217 \354\227\205\353\241\234\353\223\234</h2>\n              </div>\n              <span className=\"text-[11px] text-stone-400\">\354\240\225\353\260\200 \354\235\264\353\257\270\354\247\200 \355\214\220\353\217\205 \352\260\200\353\212\245</span>\n            </div>\n\n            {/* Quick Presets Select Box */}\n            <div className=\"mb-5\">\n              <label className=\"block text-xs font-semibold text-stone-500 mb-2\">\354\213\244\354\213\234\352\260\204 \352\270\260\354\266\234\353\254\270\354\240\234 \352\263\240\354\206\215 \355\224\204\353\246\254\354\205\213 (\354\266\224\354\262\234)</label>\n              <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-3\">\n                <button\n                  type=\"button\"\n                  onClick={() => fetchPresetData(\"killer_22\")}\n                  className={`p-4 rounded-2xl text-left border transition-all ${\n                    selectedPreset === \"killer_22\"\n                      ? \"border-red-500 bg-red-50/50 text-red-900 shadow-sm\"\n                      : \"border-stone-200 hover:bg-stone-50 text-stone-600\"\n                  }`}\n                >\n                  <div className=\"flex items-center justify-between mb-1\">\n                    <span className=\"text-xs font-extrabold px-2 py-0.5 rounded-full bg-red-100 text-red-600\">\354\210\230\353\212\245 22\353\262\210 \355\202\254\353\237\254</span>\n                    <TrendingUp className=\"w-3.5 h-3.5 text-red-500\" />\n                  </div>\n                  <h3 className=\"text-xs font-bold leading-tight mb-1\">\353\257\270\354\240\201\353\266\204/\353\213\244\355\225\255\355\225\250\354\210\230\354\235\230 \354\227\260\354\206\215\352\263\274 \352\267\271\355\225\234</h3>\n                  <p className=\"text-[10px] text-stone-400 truncate\">\354\227\260\354\206\215 \354\241\260\352\261\264\354\235\204 \355\231\234\354\232\251\355\225\234 \353\257\270\354\240\225\352\263\204\354\210\230 \354\266\224\353\241\240 \355\202\254\353\237\254</p>\n                </button>\n\n                <button\n                  type=\"button\"\n                  onClick={() => fetchPresetData(\"sequence_15\")}\n                  className={`p-4 rounded-2xl text-left border transition-all ${\n                    selectedPreset === \"sequence_15\"\n                      ? \"border-red-500 bg-red-50/50 text-red-900 shadow-sm\"\n                      : \"border-stone-200 hover:bg-stone-50 text-stone-600\"\n                  }`}\n                >\n                  <div className=\"flex items-center justify-between mb-1\">\n                    <span className=\"text-xs font-extrabold px-2 py-0.5 rounded-full bg-orange-100 text-orange-600\">\354\210\230\353\212\245 15\353\262\210 \354\244\200\355\202\254\353\237\254</span>\n                    <TrendingUp className=\"w-3.5 h-3.5 text-orange-500\" />\n                  </div>\n                  <h3 className=\"text-xs font-bold leading-tight mb-1\">\354\210\230\354\227\264\354\235\230 \352\267\200\353\202\251\354\240\201 \354\240\225\354\235\230 \354\227\255\354\266\224\354\240\201</h3>\n                  <p className=\"text-[10px] text-stone-400 truncate\">\354\227\255\353\260\251\355\226\245 \354\227\260\354\202\260\354\235\204 \355\206\265\355\225\234 \354\264\210\355\225\255 \354\266\224\353\241\240 \355\202\254\353\237\254</p>\n                </button>\n              </div>\n            </div>\n\n            {/* Custom File Upload Box */}\n            <div className=\"space-y-4\">\n              <div className=\"flex items-center gap-2\">\n                <div className=\"h-px flex-1 bg-stone-200\" />\n                <span className=\"text-[10px] text-stone-400 font-bold uppercase tracking-wider\">\353\230\220\353\212\224 \354\273\244\354\212\244\355\205\200 \354\227\205\353\241\234\353\223\234</span>\n                <div className=\"h-px flex-1 bg-stone-200\" />\n              </div>\n\n              <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-4\">\n                {/* File Upload Zone */}\n                <div>\n                  <label className=\"block text-xs font-semibold text-stone-500 mb-1.5\">\354\210\230\355\225\231 \354\235\264\353\257\270\354\247\200 \354\227\205\353\241\234\353\223\234 (JPG, PNG)</label>\n                  <div className=\"border-2 border-dashed border-stone-200 hover:border-red-400 rounded-2xl p-4 text-center cursor-pointer hover:bg-stone-50/50 transition-all relative\">\n                    <input\n                      type=\"file\"\n                      accept=\"image/*\"\n                      onChange={handleImageChange}\n                      className=\"absolute inset-0 w-full h-full opacity-0 cursor-pointer\"\n                    />\n                    <div className=\"flex flex-col items-center justify-center gap-1.5\">\n                      <div className=\"p-2 bg-stone-100 text-stone-500 rounded-xl\">\n                        <Upload className=\"w-4 h-4 text-red-500\" />\n                      </div>\n                      <span className=\"text-xs font-bold text-stone-700\">\353\254\270\354\240\234 \354\212\244\355\201\254\353\246\260\354\203\267 \354\230\254\353\246\254\352\270\260</span>\n                      <span className=\"text-[10px] text-stone-400\">\355\201\264\353\246\255\355\225\230\352\261\260\353\202\230 \354\227\254\352\270\260\353\241\234 \353\223\234\353\236\230\352\267\270</span>\n                    </div>\n                  </div>\n                </div>\n\n                {/* Direct Text Editor Box */}\n                <div>\n                  <label className=\"block text-xs font-semibold text-stone-500 mb-1.5\">\353\254\270\354\240\234\353\245\274 \355\205\215\354\212\244\355\212\270\353\241\234 \354\247\201\354\240\221 \354\236\205\353\240\245 (\354\204\240\355\203\235)</label>\n                  <textarea\n                    value={directText}\n                    onChange={(e) => {\n                      setDirectText(e.target.value);\n                      setSelectedPreset(\"\"); // Clear presets if custom text is used\n                    }}\n                    placeholder=\"\354\230\210: \354\202\274\354\260\250\355\225\250\354\210\230 f(x)\352\260\200 f\'(x) = 3x^2... f(3)\354\235\230 \352\260\222\354\235\204 \352\265\254\355\225\230\354\213\234\354\230\244.\"\n                    className=\"w-full h-[106px] text-xs p-3 rounded-2xl border border-stone-200 focus:outline-none focus:ring-1 focus:ring-red-500 focus:border-red-500 bg-stone-50 resize-none font-sans\"\n                  />\n                </div>\n              </div>\n\n              {/* Uploaded Preview State */}\n              {imageBase64 && (\n                <div className=\"bg-stone-50 border border-stone-200 rounded-2xl p-3.5 flex items-center justify-between gap-4 animate-fade-in\">\n                  <div className=\"flex items-center gap-3\">\n                    <img\n                      src={imageBase64}\n                      alt=\"\354\210\230\355\225\231 \353\254\270\354\240\234 \354\212\244\355\201\254\353\246\260\354\203\267\"\n                      className=\"w-14 h-14 object-cover rounded-xl border border-stone-200 shadow-sm\"\n                    />\n                    <div>\n                      <div className=\"text-xs font-bold text-stone-700 truncate max-w-[180px]\">\354\227\205\353\241\234\353\223\234\353\220\234 \354\235\264\353\257\270\354\247\200 \355\231\234\354\204\261\355\231\224 \354\231\204\353\243\214</div>\n                      <div className=\"text-[10px] text-emerald-600 flex items-center gap-1 mt-0.5\">\n                        <Check className=\"w-3.5 h-3.5\" /> \353\214\200\354\232\251\353\237\211 \352\263\240\353\260\200\353\217\204 \355\214\220\353\217\205 \353\214\200\352\270\260\354\244\221\n                      </div>\n                    </div>\n                  </div>\n                  <button\n                    type=\"button\"\n                    onClick={() => setImageBase64(\"\")}\n                    className=\"text-xs text-stone-400 hover:text-red-500 font-semibold px-2.5 py-1 hover:bg-red-50 rounded-lg transition-all\"\n                  >\n                    \354\202\255\354\240\234\n                  </button>\n                </div>\n              )}\n            </div>\n          </section>\n\n          {/* Section 2: Creator Persona & Style Customization (3D Cards) */}\n          <section className=\"bg-white rounded-3xl p-6 shadow-sm border border-stone-200\">\n            <div className=\"flex items-center justify-between mb-4\">\n              <div className=\"flex items-center gap-2\">\n                <div className=\"bg-red-50 text-red-500 p-1.5 rounded-lg\">\n                  <Sparkles className=\"w-4 h-4\" />\n                </div>\n                <h2 className=\"text-base font-bold text-stone-800\">2\353\213\250\352\263\204. \354\210\230\353\212\245 \352\260\225\354\202\254 \355\216\230\353\245\264\354\206\214\353\202\230 \353\260\217 \353\271\204\354\243\274\354\226\274 \355\205\214\353\247\210</h2>\n              </div>\n              <span className=\"text-[11px] text-stone-400\">\353\214\200\354\202\254 \355\206\244\354\225\244\353\247\244\353\204\210 \354\204\244\354\240\225</span>\n            </div>\n\n            {/* Persona Choices */}\n            <div className=\"mb-5\">\n              <label className=\"block text-xs font-semibold text-stone-500 mb-2.5\">\354\235\274\355\203\200\352\260\225\354\202\254 \355\225\264\355\202\271 \355\231\224\353\262\225</label>\n              <div className=\"grid grid-cols-1 sm:grid-cols-3 gap-3\">\n                <button\n                  type=\"button\"\n                  onClick={() => setPersona(\"star_teacher\")}\n                  className={`p-3.5 rounded-2xl text-left border transition-all flex flex-col gap-1.5 ${\n                    persona === \"star_teacher\"\n                      ? \"border-red-500 bg-red-50/40 text-red-950 shadow-sm\"\n                      : \"border-stone-200 hover:bg-stone-50 text-stone-600\"\n                  }`}\n                >\n                  <div className=\"flex items-center gap-1.5\">\n                    <span className=\"text-base\">\360\237\223\243</span>\n                    <span className=\"text-xs font-extrabold\">\353\214\200\354\271\230\353\217\231 \354\235\274\355\203\200\352\260\225\354\202\254</span>\n                  </div>\n                  <p className=\"text-[10px] text-stone-400 leading-tight\">\354\227\220\353\204\210\354\240\234\355\213\261\355\225\230\352\263\240 \355\231\225\354\213\240\354\227\220 \354\260\254 \354\226\264\354\241\260, \"\353\254\264\354\241\260\352\261\264 \354\266\234\354\240\234\353\220\251\353\213\210\353\213\244!\"</p>\n                </button>\n\n                <button\n                  type=\"button\"\n                  onClick={() => setPersona(\"snu_mentor\")}\n                  className={`p-3.5 rounded-2xl text-left border transition-all flex flex-col gap-1.5 ${\n                    persona === \"snu_mentor\"\n                      ? \"border-red-500 bg-red-50/40 text-red-950 shadow-sm\"\n                      : \"border-stone-200 hover:bg-stone-50 text-stone-600\"\n                  }`}\n                >\n                  <div className=\"flex items-center gap-1.5\">\n                    <span className=\"text-base\">\360\237\222\241</span>\n                    <span className=\"text-xs font-extrabold\">\354\204\234\354\232\270\353\214\200 \354\235\230\353\214\200\354\203\235 \354\204\240\353\260\260</span>\n                  </div>\n                  <p className=\"text-[10px] text-stone-400 leading-tight\">\354\260\250\353\266\204\355\225\230\352\263\240 \353\252\205\354\262\240\355\225\234 \354\240\204\353\236\265, \354\213\234\355\227\230\354\236\245 \353\271\204\353\262\225 \354\240\204\354\210\230</p>\n                </button>\n\n                <button\n                  type=\"button\"\n                  onClick={() => setPersona(\"math_savior\")}\n                  className={`p-3.5 rounded-2xl text-left border transition-all flex flex-col gap-1.5 ${\n                    persona === \"math_savior\"\n                      ? \"border-red-500 bg-red-50/40 text-red-950 shadow-sm\"\n                      : \"border-stone-200 hover:bg-stone-50 text-stone-600\"\n                  }`}\n                >\n                  <div className=\"flex items-center gap-1.5\">\n                    <span className=\"text-base\">\360\237\224\245</span>\n                    <span className=\"text-xs font-extrabold\">\354\210\230\355\217\254\354\236\220 \352\265\254\354\233\220\354\236\220</span>\n                  </div>\n                  <p className=\"text-[10px] text-stone-400 leading-tight\">\354\225\204\354\243\274 \354\211\275\352\263\240 \354\234\240\354\276\214\355\225\234 \353\271\204\354\234\240, \"\354\264\210\353\223\261\355\225\231\354\203\235\353\217\204 \354\235\264\355\225\264 \352\260\200\353\212\245!\"</p>\n                </button>\n              </div>\n            </div>\n\n            {/* Background Theme Choices */}\n            <div>\n              <label className=\"block text-xs font-semibold text-stone-500 mb-2\">\354\210\217\354\270\240 \353\271\204\354\243\274\354\226\274 \355\205\234\355\224\214\353\246\277</label>\n              <div className=\"grid grid-cols-2 sm:grid-cols-4 gap-2.5\">\n                {[\n                  { id: \"blackboard\", label: \"\353\240\210\355\212\270\353\241\234 \353\266\204\355\225\204 \354\271\240\355\214\220\", emoji: \"\360\237\237\242\" },\n                  { id: \"cyberpunk\", label: \"\353\204\244\354\230\250 \354\202\254\354\235\264\353\262\204\355\216\221\355\201\254\", emoji: \"\342\232\241\" },\n                  { id: \"graph\", label: \"\354\210\230\355\225\231 \353\252\250\353\210\210\354\242\205\354\235\264\", emoji: \"\360\237\223\220\" },\n                  { id: \"pastel\", label: \"\352\260\220\354\204\261 \355\214\214\354\212\244\355\205\224 \355\225\221\355\201\254\", emoji: \"\360\237\214\270\" },\n                ].map((t) => (\n                  <button\n                    key={t.id}\n                    type=\"button\"\n                    onClick={() => setBackgroundTheme(t.id)}\n                    className={`p-2.5 rounded-xl border text-xs font-bold text-center transition-all flex items-center justify-center gap-1.5 ${\n                      backgroundTheme === t.id\n                        ? \"border-stone-900 bg-stone-900 text-white shadow-sm\"\n                        : \"border-stone-200 hover:bg-stone-50 text-stone-700\"\n                    }`}\n                  >\n                    <span>{t.emoji}</span>\n                    <span className=\"truncate\">{t.label}</span>\n                  </button>\n                ))}\n              </div>\n            </div>\n          </section>\n\n          {/* Trigger Action Button */}\n          <button\n            type=\"button\"\n            onClick={generateShorts}\n            disabled={isGenerating}\n            className={`w-full py-4 px-6 rounded-3xl text-sm font-bold shadow-lg flex items-center justify-center gap-2.5 transition-all text-white ${\n              isGenerating\n                ? \"bg-stone-400 cursor-not-allowed\"\n                : \"bg-red-500 hover:bg-red-600 active:scale-[0.98] shadow-red-200\"\n            }`}\n          >\n            {isGenerating ? (\n              <>\n                <RefreshCw className=\"w-5 h-5 animate-spin\" />\n                <span>{loadingStep}</span>\n              </>\n            ) : (\n              <>\n                <Sparkles className=\"w-5 h-5\" />\n                <span>AI \354\210\230\353\212\245 \354\210\230\355\225\231 \354\210\217\354\270\240 \355\222\200\354\235\264 \354\240\234\354\236\221\355\225\230\352\270\260</span>\n              </>\n            )}\n          </button>\n\n          {/* Solution Metadata Board */}\n          {shortsData && (\n            <div className=\"bg-stone-800 text-stone-100 rounded-3xl p-6 shadow-md border border-stone-700 space-y-4\">\n              <div className=\"flex items-center justify-between\">\n                <span className=\"text-xs font-extrabold px-3 py-1 rounded-full bg-yellow-400 text-stone-950 flex items-center gap-1\">\n                  <GraduationCap className=\"w-3.5 h-3.5\" />\n                  \352\260\234\353\205\220 \355\225\264\355\202\271 \354\231\204\353\243\214\n                </span>\n                <span className=\"text-xs text-stone-400 font-mono\">{shortsData.concept}</span>\n              </div>\n              <h3 className=\"text-lg font-bold text-white leading-tight\">{shortsData.title}</h3>\n              <p className=\"text-xs text-stone-300 leading-relaxed bg-stone-900/60 p-3.5 rounded-2xl border border-stone-700 font-mono\">\n                <strong>\355\214\220\353\217\205\353\220\234 \354\233\220\353\263\270 \353\254\270\354\240\234:</strong><br />\n                {shortsData.parsedProblemText}\n              </p>\n              \n              <div className=\"bg-red-500/10 border border-red-500/30 rounded-2xl p-4 flex gap-3\">\n                <div className=\"text-red-400 p-1 bg-red-500/20 rounded-xl self-start\">\n                  <Zap className=\"w-5 h-5\" />\n                </div>\n                <div>\n                  <h4 className=\"text-xs font-bold text-red-300 mb-0.5\">\353\214\200\354\271\230\353\217\231 \354\213\234\355\201\254\353\246\277 \354\240\225\353\263\265 \354\271\230\355\212\270\355\202\244 (Takeaway)</h4>\n                  <p className=\"text-xs text-stone-200 leading-relaxed\">{shortsData.takeaway}</p>\n                </div>\n              </div>\n            </div>\n          )}\n\n          {/* Section 3: Interactive Sandbox (Practice) */}\n          {shortsData && (\n            <section className=\"bg-white rounded-3xl p-6 shadow-sm border border-stone-200\">\n              <div className=\"flex items-center justify-between mb-4\">\n                <div className=\"flex items-center gap-2\">\n                  <div className=\"bg-red-50 text-red-500 p-1.5 rounded-lg\">\n                    <BookOpen className=\"w-4 h-4\" />\n                  </div>\n                  <h2 className=\"text-base font-bold text-stone-800\">3\353\213\250\352\263\204. 1\353\223\261\352\270\211 \352\260\200\354\206\215 \354\234\240\354\202\254 \353\254\270\354\240\234 \355\212\270\353\240\210\354\235\264\353\213\235</h2>\n                </div>\n                <span className=\"text-xs font-bold text-emerald-600 flex items-center gap-1\">\n                  <CheckCircle className=\"w-3.5 h-3.5\" /> 100% \354\240\225\352\265\220\355\225\234 AI \354\266\234\354\240\234\n                </span>\n              </div>\n              \n              <p className=\"text-xs text-stone-500 leading-relaxed mb-4\">\n                \353\260\251\352\270\210 \353\263\270 \354\210\217\354\270\240\354\235\230 <strong>{shortsData.concept}</strong> \352\260\234\353\205\220\354\235\204 \354\231\204\353\262\275\355\236\210 \355\235\241\354\210\230\355\226\210\353\212\224\354\247\200 \352\262\200\354\246\235\355\225\264\353\263\264\354\204\270\354\232\224. \n                AI\352\260\200 \354\234\240\354\202\254\355\225\234 \353\263\200\355\230\225 \354\210\230\353\212\245 \353\254\270\354\240\234\353\245\274 \354\246\211\354\204\235 \354\266\234\354\240\234\355\225\251\353\213\210\353\213\244.\n              </p>\n\n              {!practiceQuestion ? (\n                <button\n                  type=\"button\"\n                  onClick={handleGenerateSandboxProblem}\n                  disabled={practiceIsLoading}\n                  className=\"w-full py-3.5 bg-stone-900 hover:bg-stone-800 text-white rounded-2xl text-xs font-bold flex items-center justify-center gap-2 transition-all disabled:bg-stone-400\"\n                >\n                  {practiceIsLoading ? (\n                    <>\n                      <RefreshCw className=\"w-4 h-4 animate-spin\" />\n                      <span>\354\210\230\353\212\245\352\270\211 \353\263\200\355\230\225 \353\254\270\354\240\234 \354\204\244\352\263\204 \354\244\221...</span>\n                    </>\n                  ) : (\n                    <>\n                      <Sparkles className=\"w-4 h-4 text-yellow-400\" />\n                      <span>{shortsData.concept} \354\234\240\354\202\254 \354\227\260\354\212\265 \353\254\270\354\240\234 \354\203\235\354\204\261</span>\n                    </>\n                  )}\n                </button>\n              ) : (\n                <div className=\"space-y-4 animate-fade-in bg-stone-50 p-4 rounded-2xl border border-stone-200\">\n                  <div className=\"flex items-center justify-between\">\n                    <span className=\"text-[10px] font-bold px-2 py-0.5 rounded-full bg-stone-200 text-stone-600\">\352\260\234\353\205\220: {shortsData.concept}</span>\n                    <span className=\"text-[10px] text-stone-400\">\353\202\234\354\235\264\353\217\204: {shortsData.difficulty}</span>\n                  </div>\n                  \n                  <p className=\"text-xs font-bold text-stone-800 leading-relaxed bg-white p-3 rounded-xl border border-stone-200 shadow-sm whitespace-pre-wrap\">\n                    {practiceQuestion.problem}\n                  </p>\n\n                  {/* Multiple Choice Options */}\n                  <div className=\"space-y-2\">\n                    {practiceQuestion.options.map((option: string, idx: number) => (\n                      <button\n                        key={idx}\n                        type=\"button\"\n                        disabled={hasCheckedAnswer}\n                        onClick={() => setSelectedAnswer(idx)}\n                        className={`w-full p-3 rounded-xl text-left text-xs transition-all flex items-center justify-between border ${\n                          selectedAnswer === idx\n                            ? \"bg-red-50 border-red-400 text-red-950 font-bold shadow-sm\"\n                            : \"bg-white border-stone-200 hover:bg-stone-100 text-stone-700\"\n                        }`}\n                      >\n                        <span>({idx + 1}) {option}</span>\n                        {hasCheckedAnswer && idx === practiceQuestion.correctIndex && (\n                          <CheckCircle className=\"w-4 h-4 text-emerald-500\" />\n                        )}\n                      </button>\n                    ))}\n                  </div>\n\n                  {/* Grading Actions */}\n                  <div className=\"flex gap-2 pt-2\">\n                    {!hasCheckedAnswer ? (\n                      <button\n                        type=\"button\"\n                        disabled={selectedAnswer === null}\n                        onClick={checkAnswer}\n                        className=\"flex-1 py-3 bg-red-500 hover:bg-red-600 text-white rounded-xl text-xs font-bold transition-all disabled:bg-stone-300 disabled:cursor-not-allowed\"\n                      >\n                        \354\240\225\353\213\265 \354\240\234\354\266\234 \353\260\217 \354\261\204\354\240\220\355\225\230\352\270\260\n                      </button>\n                    ) : (\n                      <div className=\"w-full space-y-3\">\n                        <div className={`p-3.5 rounded-xl text-xs flex items-center gap-2.5 ${\n                          selectedAnswer === practiceQuestion.correctIndex\n                            ? \"bg-emerald-50 border border-emerald-200 text-emerald-900\"\n                            : \"bg-red-50 border border-red-100 text-red-900\"\n                        }`}>\n                          {selectedAnswer === practiceQuestion.correctIndex ? (\n                            <>\n                              <Award className=\"w-5 h-5 text-emerald-600 animate-bounce\" />\n                              <div>\n                                <div className=\"font-extrabold\">\354\240\225\353\213\265\354\236\205\353\213\210\353\213\244! (+10\354\240\220)</div>\n                                <div className=\"text-[11px] opacity-90\">\352\260\234\353\205\220 \354\235\264\355\225\264\353\217\204\352\260\200 \354\225\204\354\243\274 \353\233\260\354\226\264\353\202\251\353\213\210\353\213\244!</div>\n                              </div>\n                            </>\n                          ) : (\n                            <>\n                              <AlertCircle className=\"w-5 h-5 text-red-600\" />\n                              <div>\n                                <div className=\"font-extrabold\">\354\230\244\353\213\265\354\236\205\353\213\210\353\213\244...</div>\n                                <div className=\"text-[11px] opacity-90\">\354\225\204\354\211\275\354\247\200\353\247\214 \355\222\200\354\235\264 \353\205\270\355\212\270\353\245\274 \352\262\200\355\206\240\355\225\264\353\263\264\354\204\270\354\232\224!</div>\n                              </div>\n                            </>\n                          )}\n                        </div>\n\n                        {/* Expandable Explanation */}\n                        <div className=\"bg-white p-3.5 rounded-xl border border-stone-200 text-xs\">\n                          <h4 className=\"font-bold text-stone-800 mb-1\">\354\203\201\354\204\270 \355\225\264\354\204\244 \353\260\217 \352\263\265\354\213\235 \353\214\200\354\236\205:</h4>\n                          <p className=\"text-[11px] text-stone-600 leading-relaxed whitespace-pre-wrap\">{practiceQuestion.explanation}</p>\n                        </div>\n\n                        <button\n                          type=\"button\"\n                          onClick={handleGenerateSandboxProblem}\n                          className=\"w-full py-2.5 border border-stone-300 hover:bg-stone-50 text-stone-700 rounded-xl text-xs font-bold flex items-center justify-center gap-1.5 transition-all\"\n                        >\n                          <RefreshCw className=\"w-3.5 h-3.5\" />\n                          \354\203\210\353\241\234\354\232\264 \354\227\260\354\212\265\353\254\270\354\240\234 \355\222\200\352\270\260\n                        </button>\n                      </div>\n                    )}\n                  </div>\n                </div>\n              )}\n            </section>\n          )}\n\n        </div>\n\n        {/* RIGHT COLUMN: Interactive Smartphone Shorts Player (5 Columns) */}\n        <div className=\"lg:col-span-5 flex flex-col items-center justify-center sticky lg:top-[90px]\">\n          \n          <div className=\"w-full max-w-[340px] relative\">\n            \n            {/* Background glowing shadows relative to the theme */}\n            <div className={`absolute -inset-1.5 rounded-[42px] blur-xl opacity-30 transition-all ${\n              backgroundTheme === \'cyberpunk\' ? \'bg-pink-500\' : backgroundTheme === \'blackboard\' ? \'bg-emerald-600\' : \'bg-rose-400\'\n            }`} />\n\n            {/* Simulated Smartphone Frame */}\n            <div className=\"relative border-4 border-stone-900 rounded-[38px] overflow-hidden bg-stone-950 aspect-[9/16] w-full flex flex-col shadow-2xl\">\n              \n              {/* Smartphone Notch */}\n              <div className=\"absolute top-0 left-1/2 transform -translate-x-1/2 w-28 h-5 bg-stone-900 rounded-b-xl z-30 flex items-center justify-center\">\n                <div className=\"w-12 h-1 bg-stone-800 rounded-full mb-1\" />\n                <div className=\"w-2 h-2 bg-stone-950 rounded-full absolute right-4 top-1.5\" />\n              </div>\n\n              {shortsData ? (\n                /* Interactive Player Screen */\n                <div className={`flex-1 flex flex-col justify-between p-4 pt-8 pb-5 relative overflow-hidden transition-all duration-300 select-none ${themeStyles.containerClass}`}>\n                  \n                  {/* Subtle Scan Lines overlay for realistic CRT/Monitor Vibe */}\n                  <div className=\"absolute inset-0 scan-line pointer-events-none z-10 opacity-40\" />\n\n                  {/* Progressive Header with Top Timer Ticks */}\n                  <div className=\"w-full space-y-3 z-20\">\n                    \n                    {/* Tick Progress Bars representing each Shorts segment */}\n                    <div className=\"flex gap-1\">\n                      {shortsData.steps.map((step, idx) => {\n                        let pct = 0;\n                        if (idx < currentStepIndex) pct = 100;\n                        else if (idx === currentStepIndex) {\n                          pct = isPlaying ? 100 : 0; // standard mock visual trigger\n                        }\n                        return (\n                          <div key={idx} className={`h-1.5 flex-1 rounded-full overflow-hidden ${themeStyles.progressBg}`}>\n                            <motion.div\n                              className={`h-full ${themeStyles.progressActive}`}\n                              initial={{ width: \"0%\" }}\n                              animate={{ width: isPlaying && idx === currentStepIndex ? \"100%\" : idx < currentStepIndex ? \"100%\" : \"0%\" }}\n                              transition={{\n                                duration: isPlaying && idx === currentStepIndex ? (step.duration / speed) : 0.1,\n                                ease: \"linear\"\n                              }}\n                            />\n                          </div>\n                        );\n                      })}\n                    </div>\n\n                    {/* Problem metadata header tags */}\n                    <div className=\"flex items-center justify-between gap-2\">\n                      <div className=\"flex items-center gap-1.5\">\n                        <span className={`text-[10px] font-extrabold px-2 py-0.5 rounded-full ${themeStyles.badgeClass}`}>\n                          {shortsData.difficulty}\n                        </span>\n                        <span className=\"text-[10px] tracking-tight opacity-75 font-mono\">\n                          {shortsData.steps[currentStepIndex]?.title}\n                        </span>\n                      </div>\n                      \n                      {/* Interactive Equalizer when TTS is speaking */}\n                      {isSpeaking && (\n                        <div className=\"flex items-end gap-0.5 text-red-500 h-5\" title=\"\352\260\225\354\202\254 \354\230\244\353\224\224\354\230\244 \355\225\264\354\204\244 \354\244\221\">\n                          <div className=\"eq-bar eq-bar-1\" />\n                          <div className=\"eq-bar eq-bar-2\" />\n                          <div className=\"eq-bar eq-bar-3\" />\n                          <div className=\"eq-bar eq-bar-4\" />\n                        </div>\n                      )}\n                    </div>\n                  </div>\n\n                  {/* CENTER CONTENT: Dynamic formula slide board */}\n                  <div className=\"flex-1 flex flex-col justify-center items-center my-4 z-20\">\n                    <AnimatePresence mode=\"wait\">\n                      <motion.div\n                        key={currentStepIndex}\n                        initial={{ opacity: 0, scale: 0.93, y: 10 }}\n                        animate={{ opacity: 1, scale: 1, y: 0 }}\n                        exit={{ opacity: 0, scale: 0.95, y: -10 }}\n                        transition={{ type: \"spring\", stiffness: 300, damping: 25 }}\n                        className={`w-full py-6 px-4 rounded-2xl flex flex-col justify-center items-center text-center shadow-inner ${themeStyles.boardClass}`}\n                      >\n                        <div className=\"text-[10px] uppercase font-bold tracking-widest opacity-60 mb-2 font-mono\">\n                          STEP {currentStepIndex + 1} OF {shortsData.steps.length}\n                        </div>\n                        \n                        {/* Core Mathematical Formulations */}\n                        <div className=\"text-sm font-bold leading-relaxed mb-3 whitespace-pre-wrap font-mono min-h-[48px] flex items-center justify-center\">\n                          {shortsData.steps[currentStepIndex]?.visualFormula}\n                        </div>\n\n                        {/* Creator Stage Tag overlay */}\n                        <div className=\"h-px w-8 bg-current opacity-30 my-2\" />\n\n                        <div className=\"text-[11px] font-bold opacity-80 uppercase tracking-widest\">\n                          {persona === \"star_teacher\" ? \"\353\214\200\354\271\230\353\217\231 1\353\223\261\352\270\211 \353\271\204\353\262\225\" : persona === \"snu_mentor\" ? \"\354\204\234\354\232\270\353\214\200 \354\213\234\355\227\230 \355\225\264\355\202\271\" : \"\354\210\230\355\225\231 \352\265\254\354\233\220 \354\240\204\353\236\265\"}\n                        </div>\n                      </motion.div>\n                    </AnimatePresence>\n                  </div>\n\n                  {/* BOTTOM SUBTITLES: Standard High-Impact Shorts overlay */}\n                  <div className=\"w-full space-y-4 z-20 bg-gradient-to-t from-black/20 p-2 rounded-xl\">\n                    \n                    {/* Animated YouTube Subtitle Box */}\n                    <div className=\"min-h-[76px] text-center px-1.5 flex items-center justify-center\">\n                      <p className=\"text-xs font-bold leading-relaxed tracking-tight text-white drop-shadow-[0_2px_4px_rgba(0,0,0,0.8)]\">\n                        {renderHighlightedExplanation(\n                          shortsData.steps[currentStepIndex]?.explanation,\n                          shortsData.steps[currentStepIndex]?.accentWords\n                        )}\n                      </p>\n                    </div>\n\n                    {/* Integrated Slider Controller */}\n                    <div className=\"flex items-center justify-between gap-2 border-t border-white/10 pt-3\">\n                      \n                      {/* Left Controls */}\n                      <div className=\"flex items-center gap-2\">\n                        <button\n                          type=\"button\"\n                          onClick={() => setIsPlaying(!isPlaying)}\n                          className=\"w-8 h-8 rounded-full bg-white text-stone-900 hover:scale-105 active:scale-95 transition-all flex items-center justify-center shadow-md cursor-pointer\"\n                        >\n                          {isPlaying ? <Pause className=\"w-4 h-4 fill-current\" /> : <Play className=\"w-4 h-4 fill-current ml-0.5\" />}\n                        </button>\n                        \n                        <span className=\"text-[10px] font-mono font-bold bg-black/40 text-white px-2 py-0.5 rounded-md\">\n                          x{speed.toFixed(2)}\n                        </span>\n                      </div>\n\n                      {/* Manual Slide Toggles */}\n                      <div className=\"flex items-center gap-1.5\">\n                        <button\n                          type=\"button\"\n                          disabled={currentStepIndex === 0}\n                          onClick={() => goToStep(currentStepIndex - 1)}\n                          className=\"p-1 text-white hover:bg-white/15 rounded-lg disabled:opacity-35 disabled:hover:bg-transparent transition-all\"\n                        >\n                          <ChevronLeft className=\"w-4 h-4\" />\n                        </button>\n                        \n                        <button\n                          type=\"button\"\n                          disabled={currentStepIndex === shortsData.steps.length - 1}\n                          onClick={() => goToStep(currentStepIndex + 1)}\n                          className=\"p-1 text-white hover:bg-white/15 rounded-lg disabled:opacity-35 disabled:hover:bg-transparent transition-all\"\n                        >\n                          <ChevronRight className=\"w-4 h-4\" />\n                        </button>\n\n                        <button\n                          type=\"button\"\n                          onClick={() => goToStep(0)}\n                          className=\"p-1 text-white hover:bg-white/15 rounded-lg transition-all\"\n                          title=\"\354\262\230\354\235\214\353\266\200\355\204\260 \354\236\254\354\203\235\"\n                        >\n                          <RotateCcw className=\"w-4 h-4\" />\n                        </button>\n                      </div>\n\n                    </div>\n                  </div>\n\n                  {/* Creator Avatar Floating bubble in Shorts style */}\n                  <div className=\"absolute right-3.5 top-28 flex flex-col gap-3 items-center z-20\">\n                    \n                    {/* Circular Avatar */}\n                    <div className=\"w-9 h-9 rounded-full border-2 border-white bg-stone-900 flex items-center justify-center shadow-lg text-sm animate-float\">\n                      {persona === \"star_teacher\" ? \"\360\237\223\243\" : persona === \"snu_mentor\" ? \"\360\237\222\241\" : \"\360\237\224\245\"}\n                    </div>\n\n                    {/* Quick playback speed cycler */}\n                    <button\n                      type=\"button\"\n                      onClick={() => {\n                        const speeds = [0.75, 1.0, 1.25, 1.5];\n                        const nextIdx = (speeds.indexOf(speed) + 1) % speeds.length;\n                        setSpeed(speeds[nextIdx]);\n                        synth.playChime(440, 0.08);\n                      }}\n                      className=\"w-8 h-8 rounded-full bg-black/50 border border-white/20 text-[9px] font-mono text-white flex items-center justify-center hover:bg-black/70 transition-all cursor-pointer\"\n                      title=\"\354\236\254\354\203\235 \354\206\215\353\217\204 \354\241\260\354\240\210\"\n                    >\n                      {speed}x\n                    </button>\n\n                    {/* Speech TTS Audio toggle */}\n                    <button\n                      type=\"button\"\n                      onClick={() => {\n                        setTtsEnabled(!ttsEnabled);\n                        if (ttsEnabled) stopSpeaking();\n                        synth.playChime(350, 0.08);\n                      }}\n                      className={`w-8 h-8 rounded-full flex items-center justify-center text-white border transition-all cursor-pointer ${\n                        ttsEnabled ? \"bg-red-500 border-red-400\" : \"bg-black/50 border-white/20\"\n                      }`}\n                      title={ttsEnabled ? \"TTS \354\235\214\354\204\261 \355\225\264\354\204\244 \354\274\234\354\247\220\" : \"TTS \354\235\214\354\204\261 \355\225\264\354\204\244 \352\272\274\354\247\220\"}\n                    >\n                      {ttsEnabled ? <Volume2 className=\"w-3.5 h-3.5\" /> : <VolumeX className=\"w-3.5 h-3.5 opacity-60\" />}\n                    </button>\n\n                    {/* Ambient Synth BGM toggle */}\n                    <button\n                      type=\"button\"\n                      onClick={() => setBgmEnabled(!bgmEnabled)}\n                      className={`w-8 h-8 rounded-full flex items-center justify-center text-white border transition-all cursor-pointer ${\n                        bgmEnabled ? \"bg-amber-500 border-amber-400 animate-pulse\" : \"bg-black/50 border-white/20\"\n                      }`}\n                      title={bgmEnabled ? \"Lofi \353\260\261\352\267\270\353\235\274\354\232\264\353\223\234 \354\227\260\354\243\274 \354\244\221\" : \"Lofi \354\227\260\354\243\274 \353\201\204\352\270\260\"}\n                    >\n                      <Music className=\"w-3.5 h-3.5\" />\n                    </button>\n                  </div>\n\n                </div>\n              ) : (\n                /* Empty / Loading State placeholder */\n                <div className=\"flex-1 bg-stone-900 flex flex-col items-center justify-center text-center p-6 text-stone-400 space-y-4\">\n                  <div className=\"bg-stone-800 p-4 rounded-full border border-stone-700 relative animate-float\">\n                    <Smartphone className=\"w-10 h-10 text-stone-500\" />\n                    <Sparkles className=\"w-5 h-5 text-red-400 absolute top-2 right-2 animate-pulse\" />\n                  </div>\n                  <div>\n                    <h4 className=\"text-sm font-bold text-stone-200\">\354\210\217\354\270\240 \354\213\234\353\256\254\353\240\210\354\235\264\355\204\260 \353\214\200\352\270\260 \354\244\221</h4>\n                    <p className=\"text-[11px] text-stone-500 mt-1 leading-relaxed\">\n                      \354\242\214\354\270\241\354\235\230 \352\270\260\354\266\234 \355\224\204\353\246\254\354\205\213\354\235\204 \355\201\264\353\246\255\355\225\230\352\261\260\353\202\230,<br />\n                      \354\210\230\355\225\231 \353\254\270\354\240\234\353\245\274 \354\227\205\353\241\234\353\223\234\355\225\230\353\251\264 9:16 \355\231\251\352\270\210\353\271\204 \354\210\217\354\270\240\352\260\200 \354\235\264\352\263\263\354\227\220 \352\260\200\354\203\201 \354\240\234\354\236\221\353\220\251\353\213\210\353\213\244.\n                    </p>\n                  </div>\n                </div>\n              )}\n\n            </div>\n          </div>\n\n          {/* Interactive Player Helper Tips */}\n          {shortsData && (\n            <div className=\"mt-4 bg-white rounded-2xl p-4 border border-stone-200 shadow-sm w-full max-w-[340px] text-[11px] text-stone-500 space-y-2\">\n              <div className=\"font-bold text-stone-700 flex items-center gap-1.5\">\n                <Volume2 className=\"w-3.5 h-3.5 text-red-500\" />\n                <span>\354\212\244\353\247\210\355\212\270 \352\270\260\353\212\245 \352\260\200\354\235\264\353\223\234</span>\n              </div>\n              <ul className=\"list-disc list-inside space-y-1\">\n                <li>\354\232\260\354\270\241 <strong className=\"text-stone-700\">Volume \354\225\204\354\235\264\354\275\230</strong>\354\235\204 \354\274\234\353\251\264 \355\225\234\352\265\255\354\226\264 \354\235\214\354\204\261 \355\225\264\354\204\244(TTS)\354\235\264 \354\236\254\354\203\235\353\220\251\353\213\210\353\213\244.</li>\n                <li>\354\232\260\354\270\241 <strong className=\"text-stone-700\">\354\235\214\354\225\205 \354\225\204\354\235\264\354\275\230</strong>\354\234\274\353\241\234 \352\260\220\354\204\261 \353\252\250\354\205\230 \354\210\230\355\225\231 Lofi BGM\354\235\204 \355\225\251\354\204\261\355\225\264\353\263\264\354\204\270\354\232\224.</li>\n                <li>\354\236\254\354\203\235 \354\206\215\353\217\204 \353\260\217 \355\205\214\353\247\210 \355\205\234\355\224\214\353\246\277\354\235\200 \354\213\244\354\213\234\352\260\204 \353\260\230\354\230\201\353\220\251\353\213\210\353\213\244.</li>\n              </ul>\n            </div>\n          )}\n\n        </div>\n\n      </main>\n\n      {/* Footer Info */}\n      <footer className=\"bg-white border-t border-stone-200 py-6 mt-12 text-center text-xs text-stone-400\">\n        <div className=\"max-w-7xl mx-auto px-4 space-y-2\">\n          <p>\302\251 2026 \354\210\230\353\212\245 \354\210\230\355\225\231 \354\210\217\354\270\240 \355\222\200\354\235\264 \354\240\234\354\236\221\352\270\260 (CSAT Math Shorts Solver). Powered by Gemini AI & Antigravity.</p>\n          <p className=\"text-[10px]\">\353\263\270 \354\204\234\353\271\204\354\212\244\353\212\224 \352\265\220\354\234\241\354\232\251 \354\210\230\355\225\231 \354\235\264\353\257\270\354\247\200 \353\266\204\354\204\235 \354\227\224\354\247\204\354\235\204 \352\270\260\353\260\230\354\234\274\353\241\234 \354\204\244\352\263\204\353\220\230\354\227\210\354\212\265\353\213\210\353\213\244. Gemini 3.5 \353\252\250\353\215\270\354\235\204 \355\206\265\355\225\264 \352\263\240\353\217\204\353\241\234 \354\266\224\354\203\201\355\231\224\353\220\234 \354\240\225\355\225\251\354\204\261 \354\246\235\353\252\205\354\235\204 \354\213\234\355\226\211\355\225\251\353\213\210\353\213\244.</p>\n        </div>\n      </footer>\n\n    </div>\n  );\n}\n"
