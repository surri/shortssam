  file_change {
    absolute_path_uri: "file:///src/index.css"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "@import url(\'https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;700&family=JetBrains+Mono:wght@500&display=swap\');\n@import \"tailwindcss\";\n\n@theme {\n  --font-sans: \"Inter\", ui-sans-serif, system-ui, sans-serif;\n  --font-display: \"Space Grotesk\", sans-serif;\n  --font-mono: \"JetBrains Mono\", monospace;\n}\n\n/* Custom Math Graph Paper Background */\n.bg-graph-pattern {\n  background-image: linear-gradient(to right, rgba(0, 0, 0, 0.05) 1px, transparent 1px),\n                    linear-gradient(to bottom, rgba(0, 0, 0, 0.05) 1px, transparent 1px);\n  background-size: 24px 24px;\n}\n\n/* Custom Chalkboard chalkboard texture */\n.bg-chalkboard-pattern {\n  background-color: #064e3b; /* emerald-950 */\n  background-image: radial-gradient(circle at 50% 50%, rgba(255, 255, 255, 0.02) 0%, transparent 100%),\n                    repeating-linear-gradient(45deg, rgba(255, 255, 255, 0.005) 0px, rgba(255, 255, 255, 0.005) 2px, transparent 2px, transparent 10px);\n}\n\n/* Cyberpunk Neon glow shadows */\n.shadow-neon-pink {\n  box-shadow: 0 0 15px rgba(236, 72, 153, 0.5), inset 0 0 10px rgba(236, 72, 153, 0.2);\n}\n\n.shadow-neon-cyan {\n  box-shadow: 0 0 15px rgba(34, 211, 238, 0.5), inset 0 0 10px rgba(34, 211, 238, 0.2);\n}\n\n/* Equalizer bounce animation */\n@keyframes eqBounce {\n  0%, 100% { height: 4px; }\n  50% { height: 24px; }\n}\n\n.eq-bar {\n  width: 3px;\n  background-color: currentColor;\n  animation: eqBounce 1s ease-in-out infinite;\n}\n\n.eq-bar-1 { animation-delay: 0.1s; }\n.eq-bar-2 { animation-delay: 0.3s; }\n.eq-bar-3 { animation-delay: 0.5s; }\n.eq-bar-4 { animation-delay: 0.2s; }\n\n/* Subtle scanning line for mobile simulator */\n.scan-line {\n  background: linear-gradient(\n    to bottom,\n    rgba(255, 255, 255, 0),\n    rgba(255, 255, 255, 0.05) 10%,\n    rgba(255, 255, 255, 0) 20%\n  );\n  background-size: 100% 10px;\n}\n\n/* Floating custom animations */\n@keyframes float {\n  0%, 100% { transform: translateY(0px); }\n  50% { transform: translateY(-6px); }\n}\n\n.animate-float {\n  animation: float 3s ease-in-out infinite;\n}\n\n/* Sparkle shine effects */\n@keyframes shine {\n  100% { left: 125%; }\n}\n\n.shine-effect {\n  position: relative;\n  overflow: hidden;\n}\n\n.shine-effect::after {\n  content: \'\';\n  position: absolute;\n  top: 0;\n  left: -75%;\n  width: 50%;\n  height: 100%;\n  background: linear-gradient(to right, rgba(255, 255, 255, 0) 0%, rgba(255, 255, 255, 0.3) 100%);\n  transform: skewX(-25deg);\n  transition: 0.75s;\n}\n\n.shine-effect:hover::after {\n  animation: shine 0.75s ease-in-out;\n}\n"
    }
