      replacement_content: "import express from \"express\";\nimport path from \"path\";\nimport dotenv from \"dotenv\";\nimport { createServer as createViteServer } from \"vite\";\nimport { GoogleGenAI, Type } from \"@google/genai\";\n\ndotenv.config();\n\nconst app = express();\nconst PORT = 3000;\n\n// Enable JSON body parsing with an increased limit for base64 image uploads\napp.use(express.json({ limit: \"15mb\" }));\n\n// Helper to initialize Gemini safely inside route handlers to prevent startup crashes if key is missing\nlet aiClient: GoogleGenAI | null = null;\nfunction getGeminiClient() {\n  if (!process.env.GEMINI_API_KEY) {\n    return null;\n  }\n  if (!aiClient) {\n    aiClient = new GoogleGenAI({\n      apiKey: process.env.GEMINI_API_KEY,\n      httpOptions: {\n        headers: {\n          \"User-Agent\": \"aistudio-build\",\n        },\n      },\n    });\n  }\n  return aiClient;\n}\n\n// Pre-defined high-quality mock data for Korean CSAT Math problems\n// This acts as a robust fallback and rapid-testing suite\nconst MOCK_SOLUTIONS: Record<string, any> = {\n  killer_22: {\n    title: \"\354\210\230\353\212\245 \354\210\230\355\225\231 22\353\262\210 30\354\264\210 \353\247\214\354\227\220 \352\262\251\355\214\214\355\225\230\352\270\260!\",\n    difficulty: \"\354\265\234\354\203\201 (\355\202\254\353\237\254)\",\n    concept: \"\354\210\230\355\225\231II - \353\213\244\355\225\255\355\225\250\354\210\230\354\235\230 \353\257\270\353\266\204\352\263\274 \354\240\201\353\266\204\",\n    parsedProblemText: \"\354\213\244\354\210\230 \354\240\204\354\262\264\354\235\230 \354\247\221\355\225\251\354\227\220\354\204\234 \354\227\260\354\206\215\354\235\270 \355\225\250\354\210\230 f(x)\352\260\200 \353\213\244\354\235\214 \354\241\260\352\261\264\354\235\204 \353\247\214\354\241\261\355\225\240 \353\225\214 f(5)\354\235\230 \352\260\222\354\235\204 \352\265\254\355\225\230\354\213\234\354\230\244. (\352\260\200) x < 1 \354\235\274 \353\225\214 f\'(x) = -x\354\235\264\352\263\240... (\353\202\230) \353\252\250\353\223\240 \354\213\244\354\210\230 x\354\227\220 \353\214\200\355\225\230\354\227\254 f(x) >= 0 \354\235\264\353\213\244.\",\n    takeaway: \"\353\213\244\355\225\255\355\225\250\354\210\230 \352\267\271\353\214\200\352\267\271\354\206\214 \354\241\260\352\261\264\352\263\274 \354\227\260\354\206\215\354\204\261 \354\241\260\352\261\264\354\235\200 \355\225\255\354\203\201 \352\262\275\352\263\204\354\240\220(x=1)\354\227\220\354\204\234\354\235\230 \355\225\250\354\210\253\352\260\222\352\263\274 \353\257\270\353\266\204\352\263\204\354\210\230 \354\235\274\354\271\230\353\241\234 \355\222\200\354\226\264\353\235\274!\",\n    steps: [\n      {\n        title: \"\354\264\210\353\260\230 3\354\264\210 \353\207\214\354\204\270\355\217\254 \352\271\250\354\232\260\352\270\260!\",\n        visualFormula: \"f(x) \354\227\260\354\206\215 \354\241\260\352\261\264 \342\236\224 x=1\354\227\220\354\204\234 \353\201\212\352\270\260\354\247\200 \354\225\212\353\212\224\353\213\244!\",\n        explanation: \"\354\225\210\353\205\225 \354\271\234\352\265\254\353\223\244! \354\230\244\353\212\230\354\235\200 \354\210\230\353\212\245 \353\213\250\352\263\250 \355\202\254\353\237\254 22\353\262\210\354\235\204 \354\210\217\354\270\240\353\241\234 \355\204\270\354\226\264\353\263\274\352\262\214! \354\235\274\353\213\250 \'\354\227\260\354\206\215\354\235\270 \355\225\250\354\210\230 f(x)\'\353\235\274\353\212\224 \353\247\220\354\235\264 \353\263\264\354\235\264\354\247\200? \352\267\270\353\237\274 x=1 \352\262\275\352\263\204\353\251\264\354\227\220\354\204\234 \353\254\264\354\241\260\352\261\264 \353\247\214\353\202\230\354\225\274 \355\225\264. \353\207\214 \353\271\204\354\232\260\354\247\200 \353\247\220\352\263\240 \353\224\261 \354\235\264\352\262\203\353\247\214 \353\250\270\353\246\254\354\227\220 \354\236\205\353\240\245\355\225\230\354\236\220!\",\n        accentWords: [\"\355\202\254\353\237\254 22\353\262\210\", \"\352\262\275\352\263\204\353\251\264\", \"\353\247\214\353\202\230\354\225\274 \355\225\264\"],\n        duration: 8\n      },\n      {\n        title: \"\355\225\265\354\213\254 \354\241\260\352\261\264 \353\262\210\354\227\255\355\225\230\352\270\260\",\n        visualFormula: \"x < 1 \354\235\274 \353\225\214 f\'(x) = -x \342\236\224 f(x) = -0.5x\302\262 + C\",\n        explanation: \"\354\241\260\352\261\264 (\352\260\200)\354\227\220\354\204\234 x\352\260\200 1\353\263\264\353\213\244 \354\236\221\354\235\204 \353\225\214 \353\257\270\353\266\204\355\225\234 \352\262\214 -x\353\235\274\352\263\240 \354\244\254\354\247\200? \354\235\264\352\261\270 \352\260\200\353\263\215\352\262\214 \354\240\201\353\266\204\355\225\230\353\251\264 f(x)\353\212\224 \354\234\204\353\241\234 \353\263\274\353\241\235\355\225\234 \354\235\264\354\260\250\355\225\250\354\210\230 \352\274\264\354\235\264 \353\217\274. \354\265\234\352\263\240\354\260\250\355\225\255 \354\235\214\354\210\230\354\235\270 \354\235\264\354\260\250\355\225\250\354\210\230, \353\250\270\353\246\277\354\206\215\354\227\220 \353\260\224\353\241\234 \352\267\270\353\240\244\354\247\200\354\247\200?\",\n        accentWords: [\"\352\260\200\353\263\215\352\262\214 \354\240\201\353\266\204\", \"\354\235\264\354\260\250\355\225\250\354\210\230\", \"\353\250\270\353\246\277\354\206\215\354\227\220\"],\n        duration: 9\n      },\n      {\n        title: \"\354\213\244\354\210\230 \354\240\204\354\262\264 f(x) >= 0 \354\223\260\352\270\260\",\n        visualFormula: \"\354\265\234\354\206\237\352\260\222 \342\236\224 f(1) >= 0 \354\235\264\352\263\240 \354\240\221\355\225\264\354\225\274 \355\225\234\353\213\244!\",\n        explanation: \"\354\241\260\352\261\264 (\353\202\230)\353\245\274 \353\264\220\353\264\220! \'\353\252\250\353\223\240 \354\213\244\354\210\230 x\354\227\220\354\204\234 f(x)\353\212\224 0 \354\235\264\354\203\201\354\235\264\353\213\244!\' \354\235\264\352\262\214 \353\214\200\353\260\225 \353\213\250\354\204\234\354\225\274. f(x)\352\260\200 \353\260\221\354\234\274\353\241\234 \353\226\250\354\226\264\354\247\200\353\251\264 \354\225\210 \353\220\230\353\213\210\352\271\214 x\354\266\225\354\227\220 \354\240\221\355\225\230\352\261\260\353\202\230 \354\234\204\354\227\220\354\204\234\353\247\214 \353\206\200\354\225\204\354\225\274 \355\225\264. \352\262\275\352\263\204\354\240\220\354\235\270 x=1\354\227\220\354\204\234 \354\212\244\354\271\230\353\223\257 \354\240\221\355\225\230\353\212\224 \355\230\225\355\203\234\352\260\200 \354\240\225\353\213\265 \354\212\244\353\251\234\354\235\264 \353\202\230\354\247\200?\",\n        accentWords: [\"0 \354\235\264\354\203\201\354\235\264\353\213\244\", \"x\354\266\225\354\227\220 \354\240\221\355\225\230\352\261\260\353\202\230\", \"\354\240\225\353\213\265 \354\212\244\353\251\234\"],\n        duration: 10\n      },\n      {\n        title: \"\353\271\204\353\260\200 \354\271\230\355\212\270\355\202\244\354\213\235 \353\247\210\353\254\264\353\246\254\",\n        visualFormula: \"f(5) = 2 \303\227 (5 - 1)\302\263 - 3 = 125\",\n        explanation: \"\354\235\264\354\240\234 \352\262\275\352\263\204\354\241\260\352\261\264\354\235\204 \353\224\261 \353\214\200\354\236\205\355\225\264\353\263\264\353\251\264, \353\257\270\353\266\204\352\260\200\353\212\245\354\204\261\352\271\214\354\247\200 \353\247\214\354\241\261\355\225\230\353\251\264\354\204\234 \352\267\270\353\236\230\355\224\204\352\260\200 \354\234\240\353\240\244\355\225\230\352\262\214 \354\227\260\352\262\260\353\220\230\353\212\224 \353\271\204\353\241\200\354\203\201\354\210\230 k=2\353\245\274 \354\211\275\352\262\214 \353\275\221\354\225\204\353\202\274 \354\210\230 \354\236\210\354\226\264. \354\232\260\353\246\254\352\260\200 \354\233\220\355\225\230\353\212\224 f(5) \352\260\222\354\227\220 \353\214\200\354\236\205\355\225\230\353\251\264 \354\240\225\353\213\265\354\235\200 125! \353\204\210\353\254\264 \354\235\264\354\247\200\355\225\230\354\247\200?\",\n        accentWords: [\"\352\262\275\352\263\204\354\241\260\352\261\264 \353\214\200\354\236\205\", \"\354\240\225\353\213\265\354\235\200 125\", \"\353\204\210\353\254\264 \354\235\264\354\247\200\355\225\230\354\247\200\"],\n        duration: 10\n      }\n    ]\n  },\n  sequence_15: {\n    title: \"\354\210\230\353\212\245 15\353\262\210 \352\267\200\353\202\251\354\240\201 \354\210\230\354\227\264 \354\210\217 \355\225\264\355\202\271!\",\n    difficulty: \"\354\203\201 (\354\244\200\355\202\254\353\237\254)\",\n    concept: \"\354\210\230\355\225\231I - \354\210\230\354\227\264\354\235\230 \352\267\200\353\202\251\354\240\201 \354\240\225\354\235\230\",\n    parsedProblemText: \"\354\210\230\354\227\264 a_n\354\235\264 \353\213\244\354\235\214 \354\241\260\352\261\264\354\235\204 \353\247\214\354\241\261\354\213\234\355\202\250\353\213\244. a_1 = 1 \354\235\264\352\263\240, a_{n+1}\354\235\200 a_n\354\235\264 \355\231\200\354\210\230\354\235\264\353\251\264 a_n + 2, \354\247\235\354\210\230\354\235\264\353\251\264 a_n / 2 \354\235\264\353\213\244. a_6 = 4\352\260\200 \353\220\230\353\217\204\353\241\235 \355\225\230\353\212\224 \353\252\250\353\223\240 \352\262\275\354\232\260\353\245\274 \352\265\254\355\225\230\354\213\234\354\230\244.\",\n    takeaway: \"\354\210\230\354\227\264\354\235\230 \354\227\255\354\266\224\354\240\201(Back-tracking)\354\235\200 \352\260\200\354\247\200\354\271\230\352\270\260 \353\217\204\354\213\235\355\231\224\353\241\234 \354\247\235\354\210\230/\355\231\200\354\210\230 \353\252\250\354\210\234\354\235\204 \354\246\211\354\213\234 \354\206\214\352\261\260\355\225\230\353\212\224 \352\262\214 \355\225\204\354\212\271\353\262\225!\",\n    steps: [\n      {\n        title: \"\354\227\255\354\266\224\354\240\201 \354\212\244\355\203\200\355\212\270 \353\201\212\352\270\260\",\n        visualFormula: \"a_6 = 4 \342\236\224 a_5\353\212\224 \352\263\274\354\227\260 \353\210\204\352\265\254\354\230\200\354\235\204\352\271\214?\",\n        explanation: \"\354\236\220, \354\210\230\353\212\245 \353\213\250\352\263\250 15\353\262\210 \354\210\230\354\227\264 \354\227\255\354\266\224\354\240\201 \353\254\270\354\240\234\354\225\274! \354\253\204\354\247\200 \353\247\210. a_6\354\235\264 4\352\260\200 \353\220\230\353\240\244\353\251\264 \354\240\204 \353\213\250\352\263\204\354\235\270 a_5\352\260\200 \355\231\200\354\210\230\354\230\200\352\261\260\353\202\230 \354\247\235\354\210\230\354\230\200\352\262\240\354\247\200? \352\261\260\352\276\270\353\241\234 \355\203\200\352\263\240 \354\230\254\353\235\274\352\260\200\353\212\224 \354\227\255\354\266\224\354\240\201 \355\212\270\353\246\254 \352\267\270\353\240\244\353\263\274 \352\261\260\354\225\274. \353\240\210\354\270\240\352\263\240!\",\n        accentWords: [\"\354\227\255\354\266\224\354\240\201 \353\254\270\354\240\234\", \"\352\261\260\352\276\270\353\241\234 \355\203\200\352\263\240\", \"\354\227\255\354\266\224\354\240\201 \355\212\270\353\246\254\"],\n        duration: 8\n      },\n      {\n        title: \"\355\231\200\354\210\230/\354\247\235\354\210\230 \352\260\200\354\247\200\354\271\230\352\270\260 \353\217\214\354\236\205\",\n        visualFormula: \"a_5 + 2 = 4 (a_5=2: \355\231\200\354\210\230 \354\225\204\353\213\230 \342\236\224 \355\203\210\353\235\275) OR a_5 / 2 = 4 (a_5=8: \354\247\235\354\210\230 \342\236\224 \355\206\265\352\263\274!)\",\n        explanation: \"\354\262\253 \353\262\210\354\247\270 \354\213\235\354\227\220\354\204\234 a_5\352\260\200 \355\231\200\354\210\230\353\235\274\353\251\264 \353\215\224\355\225\264\354\204\234 4\352\260\200 \353\220\230\353\213\210\352\271\214 a_5\353\212\224 2\352\260\200 \353\217\274\354\225\274 \355\225\230\353\212\224\353\215\260, 2\353\212\224 \354\247\235\354\210\230\354\247\200? \352\267\270\353\237\254\353\213\210\352\271\214 \354\235\264\352\261\264 \353\252\250\354\210\234\354\235\264\353\235\274 \355\203\210\353\235\275! \354\246\211 a_5\353\212\224 \353\254\264\354\241\260\352\261\264 8\353\241\234 \355\231\225\354\240\225\354\235\264\354\225\274. \354\235\264\353\240\207\352\262\214 \352\260\200\354\247\200\354\271\230\352\270\260\353\245\274 \352\260\200\354\260\250\354\227\206\354\235\264 \354\236\230\353\235\274\353\202\264!\",\n        accentWords: [\"\353\252\250\354\210\234\354\235\264\353\235\274 \355\203\210\353\235\275\", \"8\353\241\234 \355\231\225\354\240\225\", \"\352\260\200\354\247\200\354\271\230\352\270\260\"],\n        duration: 10\n      },\n      {\n        title: \"\354\255\211\354\255\211 \354\271\230\352\263\240 \354\230\254\353\235\274\352\260\200\352\270\260\",\n        visualFormula: \"a_5 = 8 \342\236\224 a_4 = 6 (\355\231\200\354\210\230 \355\203\210\353\235\275) OR a_4 = 16 (\354\247\235\354\210\230 \355\206\265\352\263\274!)\",\n        explanation: \"\352\260\231\354\235\200 \353\260\251\353\262\225\354\234\274\353\241\234 a_5\352\260\200 8\354\235\264\353\213\210\352\271\214, a_4\353\212\224 \355\231\200\354\210\230\353\235\274\353\251\264 6\354\235\264\354\226\264\354\225\274 \355\225\230\353\212\224\353\215\260 6\354\235\200 \354\247\235\354\210\230\353\213\210\352\271\214 \355\203\210\353\235\275! \352\262\260\352\265\255 a_4\353\212\224 \353\254\264\354\241\260\352\261\264 16\354\235\264 \353\220\230\353\212\224 \352\261\260\354\247\200. \354\235\264 \353\213\250\354\210\234 \352\263\204\354\202\260 3\354\264\210 \354\273\267\354\235\264\354\247\200?\",\n        accentWords: [\"a_4\353\212\224 \353\254\264\354\241\260\352\261\264 16\", \"\353\213\250\354\210\234 \352\263\204\354\202\260\", \"3\354\264\210 \354\273\267\"],\n        duration: 8\n      },\n      {\n        title: \"\354\265\234\354\242\205 \354\240\225\353\213\265 \354\240\200\352\262\251 \354\231\204\353\243\214!\",\n        visualFormula: \"\353\252\250\353\223\240 \352\260\200\353\212\245\354\204\261 \354\241\260\355\225\251 \342\236\224 \353\247\214\354\241\261\355\225\230\353\212\224 \354\264\210\355\225\255 \355\225\251 \352\265\254\355\225\230\352\270\260\",\n        explanation: \"\354\235\264\353\237\260 \353\260\251\354\213\235\354\234\274\353\241\234 \352\267\234\354\271\231\354\240\201\354\234\274\353\241\234 \354\263\220\353\202\264\353\213\244 \353\263\264\353\251\264 a_1=1\354\227\220\354\204\234 \354\213\234\354\236\221\355\225\264 \354\241\260\352\261\264\354\227\220 \353\266\200\355\225\251\355\225\230\353\212\224 \354\210\230\354\227\264\354\235\230 \355\214\250\355\204\264\354\235\264 \354\231\204\354\204\261\353\217\274! \352\267\200\354\260\256\354\235\200 \354\210\230\354\227\264 \353\254\270\354\240\234\353\217\204 \354\210\217\354\270\240\354\262\230\353\237\274 \354\203\235\352\260\201\355\225\230\353\251\264 \354\247\201\352\264\200\354\240\201\354\234\274\353\241\234 \355\222\200 \354\210\230 \354\236\210\354\226\264. \353\263\265\354\212\265 \355\225\204\354\210\230!\",\n        accentWords: [\"\354\210\230\354\227\264\354\235\230 \355\214\250\355\204\264\", \"\354\247\201\352\264\200\354\240\201\354\234\274\353\241\234\", \"\353\263\265\354\212\265 \355\225\204\354\210\230\"],\n        duration: 9\n      }\n    ]\n  }\n};\n\n// API Endpoint to process and solve mathematics problem image\napp.post(\"/api/solve-math\", async (req, res) => {\n  try {\n    const { imageBase64, mimeType, persona, presetKey } = req.body;\n\n    // Handle standard demo triggers instantly to conserve token usage or if API key isn\'t setup\n    if (presetKey && MOCK_SOLUTIONS[presetKey]) {\n      // Modify mock data slightly if a custom persona is selected\n      const baseMock = JSON.parse(JSON.stringify(MOCK_SOLUTIONS[presetKey]));\n      if (persona) {\n        baseMock.steps = baseMock.steps.map((step: any, index: number) => {\n          let updatedExp = step.explanation;\n          if (persona === \"star_teacher\") {\n            updatedExp = \"\360\237\223\243 [\354\212\244\355\203\200\352\260\225\354\202\254] \" + updatedExp.replace(\"\354\225\210\353\205\225 \354\271\234\352\265\254\353\223\244!\", \"\354\236\220! \354\247\221\354\244\221\355\225\230\354\204\270\354\232\224 \354\210\230\355\227\230\354\203\235 \354\227\254\353\237\254\353\266\204!\").replace(\"\353\240\210\354\270\240\352\263\240!\", \"\353\254\264\354\241\260\352\261\264 \354\266\234\354\240\234\353\220\251\353\213\210\353\213\244!\");\n          } else if (persona === \"snu_mentor\") {\n            updatedExp = \"\360\237\222\241 [\354\204\234\354\232\270\353\214\200 \354\235\230\353\214\200\354\203\235] \" + updatedExp.replace(\"\354\225\210\353\205\225 \354\271\234\352\265\254\353\223\244!\", \"\354\204\240\353\260\260\352\260\200 \352\260\200\353\245\264\354\263\220\354\243\274\353\212\224 \354\210\230\353\212\245 \355\214\201\354\235\264\353\213\244.\").replace(\"\354\253\204\354\247\200 \353\247\210.\", \"\353\251\224\355\203\200\354\235\270\354\247\200\354\240\201\354\234\274\353\241\234 \354\260\250\352\267\274\354\260\250\352\267\274 \352\265\254\354\241\260\355\231\224\355\225\230\354\236\220.\");\n          } else if (persona === \"math_savior\") {\n            updatedExp = \"\360\237\224\245 [\354\210\230\355\217\254\354\236\220 \352\265\254\354\233\220\354\236\220] \" + updatedExp.replace(\"\354\225\210\353\205\225 \354\271\234\352\265\254\353\223\244!\", \"\354\210\230\355\217\254\354\236\220 \355\203\210\354\266\234 \354\244\200\353\271\204\353\220\220\353\203\220? \353\207\214 \355\222\200\352\263\240 \353\223\244\354\226\264\354\231\200!\").replace(\"\353\204\210\353\254\264 \354\235\264\354\247\200\355\225\230\354\247\200?\", \"\354\226\264\353\225\214, \354\264\210\353\223\261\355\225\231\354\203\235\353\217\204 \355\222\200 \354\210\230 \354\236\210\354\247\200?\");\n          }\n          return { ...step, explanation: updatedExp };\n        });\n      }\n      return res.json({ success: true, data: baseMock });\n    }\n\n    const ai = getGeminiClient();\n    if (!ai) {\n      // No API key found, return informative instructions + automatic fallbacks so it never errors\n      return res.json({\n        success: true,\n        isDemo: true,\n        message: \"Gemini API Key\352\260\200 \354\204\244\354\240\225\353\220\230\354\247\200 \354\225\212\354\225\204 \353\215\260\353\252\250 \353\252\250\353\223\234\353\241\234 \354\236\220\353\217\231 \354\240\204\355\231\230\353\220\230\354\227\210\354\212\265\353\213\210\353\213\244. \354\210\230\353\212\245 \355\202\254\353\237\254\353\254\270\355\225\255 22\353\262\210 \354\203\230\355\224\214\353\241\234 \352\260\200\354\203\201\354\235\230 \354\210\217\354\270\240 \355\222\200\354\235\264\353\245\274 \354\240\234\354\236\221\355\225\251\353\213\210\353\213\244.\",\n        data: MOCK_SOLUTIONS.killer_22\n      });\n    }\n\n    if (!imageBase64) {\n      return res.status(400).json({ error: \"\354\235\264\353\257\270\354\247\200 \353\215\260\354\235\264\355\204\260\352\260\200 \354\240\204\354\206\241\353\220\230\354\247\200 \354\225\212\354\225\230\354\212\265\353\213\210\353\213\244.\" });\n    }\n\n    // Clean base64 string\n    const cleanBase64 = imageBase64.replace(/^data:image\\/\\w+;base64,/, \"\");\n\n    // Prepare prompt according to the selected persona\n    let personaPrompt = \"\354\210\230\353\212\245 \354\235\274\355\203\200\352\260\225\354\202\254 (\354\227\220\353\204\210\354\240\234\355\213\261\355\225\230\352\263\240 \354\271\264\353\246\254\354\212\244\353\247\210 \353\204\230\354\271\230\353\212\224 \353\247\220\355\210\254, \354\210\217\354\270\240 \354\236\220\353\247\211\354\262\230\353\237\274 \352\270\264\353\260\225\355\225\230\352\263\240 \352\267\200\354\227\220 \354\217\231\354\217\231 \353\260\225\355\236\230)\";\n    if (persona === \"snu_mentor\") {\n      personaPrompt = \"\354\204\234\354\232\270\353\214\200 \354\235\230\353\214\200\354\203\235 \354\204\240\353\260\260 (\354\260\250\353\266\204\355\225\230\353\251\264\354\204\234\353\217\204 \354\213\234\355\227\230\354\236\245 \355\225\264\355\202\271 \354\271\230\355\212\270\355\202\244, \353\251\224\355\203\200\354\235\270\354\247\200\353\245\274 \352\271\250\354\233\214\354\243\274\353\212\224 \354\247\201\352\264\200\354\240\201 \354\235\274\354\271\250)\";\n    } else if (persona === \"math_savior\") {\n      personaPrompt = \"\354\210\230\355\217\254\354\236\220 \352\265\254\354\233\220\354\236\220 (\354\210\230\355\225\231 \355\217\254\352\270\260\354\236\220\353\217\204 \353\213\250\354\210\250\354\227\220 \354\233\203\354\234\274\353\251\260 \354\235\264\355\225\264\355\225\240 \354\210\230 \354\236\210\353\212\224 \354\225\204\354\243\274 \354\234\240\354\276\214\355\225\230\352\263\240 \353\271\204\354\234\240\354\240\201\354\235\264\353\251\260 \354\234\240\353\250\270\353\237\254\354\212\244\355\225\234 \353\247\220\355\210\254)\";\n    }\n\n    const promptText = `\n\353\204\210\353\212\224 \353\214\200\355\225\234\353\257\274\352\265\255 \354\265\234\352\263\240\354\235\230 \354\210\230\353\212\245 \354\210\230\355\225\231 \354\234\240\355\212\234\353\270\214 \354\210\217\354\270\240(Shorts) \355\201\254\353\246\254\354\227\220\354\235\264\355\204\260\354\235\264\354\236\220 \352\265\220\354\234\241 \354\240\204\353\254\270\352\260\200\354\225\274.\n\354\227\205\353\241\234\353\223\234\353\220\234 \354\210\230\353\212\245 \354\210\230\355\225\231 \353\254\270\354\240\234 \354\235\264\353\257\270\354\247\200\353\245\274 \354\231\204\353\262\275\355\225\230\352\262\214 \355\214\220\353\217\205\355\225\230\354\227\254, 9:16 \353\271\204\354\234\250\354\235\230 \354\210\217\354\270\240 \353\271\204\353\224\224\354\230\244 \355\230\225\355\203\234\353\241\234 \352\265\254\354\204\261\355\225\240 \354\210\230 \354\236\210\353\212\224 \353\213\250\352\263\204\353\263\204 \353\271\204\354\243\274\354\226\274 \355\222\200\354\235\264 \354\213\234\353\202\230\353\246\254\354\230\244\353\245\274 JSON \355\230\225\355\203\234\353\241\234 \354\236\221\354\204\261\355\225\264\354\244\230.\n\n[\354\210\217\354\270\240 \354\273\250\354\205\211 \352\260\200\354\235\264\353\223\234\353\235\274\354\235\270]\n1. \354\210\217\354\270\240\353\212\224 \354\206\215\353\217\204\352\260\220\354\235\264 \354\203\235\353\252\205\354\235\264\354\225\274. \353\263\265\354\236\241\355\225\230\352\263\240 \352\270\264 \354\244\204\352\270\200 \354\204\244\353\252\205 \353\214\200\354\213\240, \355\225\234 \353\213\250\352\263\204\354\227\220 \355\225\265\354\213\254 \352\263\265\354\213\235 1\352\260\234\354\231\200 \353\210\210\354\227\220 \352\275\202\355\236\210\353\212\224 \353\251\230\355\212\270 1~2\352\260\234\353\241\234 \352\265\254\354\204\261\355\225\264\354\244\230.\n2. \352\260\201 \355\222\200\354\235\264 \353\213\250\352\263\204\353\247\210\353\213\244 \355\231\224\353\251\264\354\227\220 \355\201\254\352\262\214 \353\235\204\354\233\214\354\244\204 \'\355\225\265\354\213\254 \352\263\265\354\213\235/\352\264\200\352\263\204\354\213\235(visualFormula)\'\352\263\274, \355\201\254\353\246\254\354\227\220\354\235\264\355\204\260\352\260\200 \354\227\220\353\204\210\354\240\234\355\213\261\355\225\230\352\262\214 \353\247\220\353\241\234 \353\202\264\353\261\211\354\235\204 \'\352\265\254\354\226\264\354\262\264 \353\214\200\354\202\254(explanation)\'\353\245\274 \354\231\204\353\262\275\355\236\210 \353\247\244\354\271\255\355\225\264\354\244\230.\n3. \354\236\220\353\247\211 \355\232\250\352\263\274\353\245\274 \354\243\274\352\270\260 \354\234\204\355\225\264 \352\260\201 \353\213\250\352\263\204 \353\214\200\354\202\254\354\227\220\354\204\234 \352\260\200\354\236\245 \354\236\204\355\214\251\355\212\270 \354\236\210\353\212\224 \355\225\265\354\213\254 \353\213\250\354\226\264 3\352\260\234\353\245\274 \'\352\260\225\354\241\260 \353\213\250\354\226\264(accentWords)\' \353\260\260\354\227\264\354\227\220 \354\247\200\354\240\225\355\225\264\354\244\230. \354\235\264 \353\213\250\354\226\264\353\223\244\354\235\200 \355\231\224\353\251\264 \354\236\220\353\247\211\354\227\220\354\204\234 \354\273\254\353\237\254 \355\205\215\354\212\244\355\212\270\353\241\234 \354\227\260\354\266\234\353\220\240 \352\261\260\354\225\274.\n4. \355\222\200\354\235\264\353\245\274 \352\267\270\353\203\245 \353\202\230\354\227\264\355\225\230\353\212\224 \352\262\214 \354\225\204\353\213\210\353\235\274, \355\203\200\352\262\237 \355\216\230\353\245\264\354\206\214\353\202\230\354\235\230 \353\247\244\353\240\245\354\235\204 \352\267\271\353\214\200\355\231\224\355\225\264\354\204\234 \354\236\221\354\204\261\355\225\264\354\244\230.\n   \355\230\204\354\236\254 \355\203\200\352\262\237 \355\201\254\353\246\254\354\227\220\354\235\264\355\204\260 \355\216\230\353\245\264\354\206\214\353\202\230: ${personaPrompt}\n\n\353\260\230\353\223\234\354\213\234 \353\213\244\354\235\214 JSON \354\212\244\355\202\244\353\247\210\353\245\274 100% \354\244\200\354\210\230\355\225\230\354\227\254 \354\235\221\353\213\265\355\225\264\354\244\230. \353\213\244\353\245\270 \353\247\210\355\201\254\353\213\244\354\232\264 \355\205\215\354\212\244\355\212\270\353\202\230 \354\204\244\353\252\205 \354\227\206\354\235\264 \354\210\234\354\210\230 JSON\353\247\214 \353\260\230\355\231\230\355\225\264\354\225\274 \355\225\264:\n\n{\n  \"title\": \"\353\210\210\354\227\220 \353\235\204\353\212\224 \354\210\217\354\270\240\354\232\251 \354\240\234\353\252\251 (\354\230\210: \'\354\210\230\353\212\245 30\353\262\210 30\354\264\210 \354\273\267 \352\260\200\353\212\245?\', \'\352\263\265\354\213\235 \354\227\206\354\235\264 \355\221\270\353\212\224 15\353\262\210\')\",\n  \"difficulty\": \"\353\202\234\354\235\264\353\217\204 \355\217\211\352\260\200 (\354\230\210: \'\354\265\234\354\203\201(\355\202\254\353\237\254)\', \'\354\203\201(\354\244\200\355\202\254\353\237\254)\', \'\354\244\221(\355\217\211\354\235\264)\')\",\n  \"concept\": \"\354\266\234\354\240\234\353\220\234 \352\265\220\352\263\274 \353\213\250\354\233\220 \353\260\217 \355\225\265\354\213\254 \352\260\234\353\205\220 (\354\230\210: \'\354\210\230\355\225\231I - \354\247\200\354\210\230\355\225\250\354\210\230\', \'\353\257\270\354\240\201\353\266\204 - \354\202\274\352\260\201\355\225\250\354\210\230\354\235\230 \352\267\271\355\225\234\')\",\n  \"parsedProblemText\": \"\354\235\264\353\257\270\354\247\200\354\227\220\354\204\234 \353\266\204\354\204\235\355\225\264\353\202\270 \354\210\230\355\225\231 \353\254\270\354\240\234 \355\205\215\354\212\244\355\212\270 \354\232\224\354\225\275\",\n  \"takeaway\": \"\354\235\264 \353\254\270\354\240\234\353\245\274 \355\222\200 \353\225\214 \354\210\230\355\227\230\354\203\235\353\223\244\354\235\264 \354\213\234\355\227\230\354\236\245\354\227\220\354\204\234 \353\254\264\354\241\260\352\261\264 \352\270\260\354\226\265\355\225\264\354\225\274 \355\225\240 \354\264\210\352\260\225\353\240\245 \354\271\230\355\212\270\355\202\244 \355\225\234 \354\244\204 \354\240\225\353\246\254\",\n  \"steps\": [\n    {\n      \"title\": \"\353\213\250\352\263\204\353\245\274 \353\202\230\355\203\200\353\202\264\353\212\224 \354\247\247\352\263\240 \355\236\231\355\225\234 \354\206\214\354\240\234\353\252\251 (\354\230\210: \'1\354\264\210\353\247\214\354\227\220 \354\241\260\352\261\264 \354\272\220\354\271\230\355\225\230\352\270\260\', \'\354\235\264\354\260\250\355\225\250\354\210\230 \353\271\204\354\234\250 \353\271\204\352\270\260\')\",\n      \"visualFormula\": \"\355\231\224\353\251\264\354\227\220 \355\201\254\352\262\214 \353\217\204\354\213\235\355\231\224\355\225\230\354\227\254 \353\235\204\354\233\214\354\244\204 \355\225\265\354\213\254 \354\210\230\354\213\235 \353\230\220\353\212\224 \354\210\230\355\225\231\354\240\201 \354\233\220\353\246\254 (LaTeX \354\212\244\355\203\200\354\235\274 \353\230\220\353\212\224 \354\225\214\354\225\204\353\263\264\352\270\260 \354\211\254\354\232\264 \354\235\264\353\252\250\355\213\260\354\275\230 \354\234\265\355\225\251 \354\210\230\354\213\235)\",\n      \"explanation\": \"\355\201\254\353\246\254\354\227\220\354\235\264\355\204\260\352\260\200 \354\210\217\354\270\240\354\227\220\354\204\234 \354\213\244\354\240\234\353\241\234 \353\247\220\355\225\230\353\212\224 \352\265\254\354\226\264\354\262\264 \355\225\234\352\270\200 \353\214\200\354\202\254 (\355\225\234 \353\213\250\352\263\204\353\213\271 2~3\353\254\270\354\236\245 \354\235\264\353\202\264\353\241\234 \354\203\235\353\217\231\352\260\220 \353\204\230\354\271\230\352\263\240 \354\236\220\354\213\240\352\260\220 \354\236\210\352\262\214!)\",\n      \"accentWords\": [\"\353\214\200\354\202\254\", \"\354\206\215\354\227\220\354\204\234\", \"\352\260\225\354\241\260\355\225\240\353\213\250\354\226\2643\352\260\234\"],\n      \"duration\": \352\260\201 \353\213\250\352\263\204\353\263\204 \352\266\214\354\236\245 \355\231\224\353\251\264 \354\234\240\354\247\200 \354\213\234\352\260\204 (\354\264\210 \353\213\250\354\234\204 \354\240\225\354\210\230, \353\263\264\355\206\265 7~10\354\264\210 \353\202\264\354\231\270)\"\n    }\n  ]\n}\n\n- \353\213\250\352\263\204(steps)\353\212\224 \353\204\210\353\254\264 \352\270\270\354\226\264\354\247\200\353\251\264 \354\210\217\354\270\240 \353\243\250\354\246\210\355\225\264\354\247\200\353\213\210\352\271\214 \354\265\234\354\206\214 3\353\213\250\352\263\204\354\227\220\354\204\234 \354\265\234\353\214\200 5\353\213\250\352\263\204 \354\202\254\354\235\264\353\241\234 \354\240\201\354\240\210\355\236\210 \353\247\236\354\266\260\354\244\230.\n- \354\210\230\355\225\231\354\240\201 \354\240\225\355\225\251\354\204\261\354\235\204 \354\227\204\352\262\251\355\225\230\352\262\214 \354\247\200\354\274\234\354\204\234 \353\254\270\354\240\234\353\245\274 \355\231\225\354\213\244\355\225\230\352\262\214 \355\222\200\354\226\264\354\244\230.\n`;\n\n    const imagePart = {\n      inlineData: {\n        mimeType: mimeType || \"image/png\",\n        data: cleanBase64,\n      },\n    };\n\n    const textPart = {\n      text: promptText,\n    };\n\n    const response = await ai.models.generateContent({\n      model: \"gemini-3.5-flash\",\n      contents: { parts: [imagePart, textPart] },\n      config: {\n        responseMimeType: \"application/json\",\n      },\n    });\n\n    const resultText = response.text || \"{}\";\n    const parsedData = JSON.parse(resultText.trim());\n\n    return res.json({ success: true, data: parsedData });\n  } catch (error: any) {\n    console.error(\"\354\210\230\355\225\231 \353\254\270\354\240\234 \353\266\204\354\204\235 \354\230\244\353\245\230:\", error);\n    return res.status(500).json({\n      error: \"\354\210\230\355\225\231 \353\254\270\354\240\234\353\245\274 \353\266\204\354\204\235\355\225\230\353\212\224 \354\244\221 \354\230\244\353\245\230\352\260\200 \353\260\234\354\203\235\355\226\210\354\212\265\353\213\210\353\213\244.\",\n      details: error.message,\n    });\n  }\n});\n\n// Endpoint to generate similar problem using Gemini for active sandbox learning\napp.post(\"/api/generate-similar\", async (req, res) => {\n  try {\n    const { concept, difficulty } = req.body;\n    const ai = getGeminiClient();\n\n    if (!ai) {\n      // Safe fallback when API key is not ready\n      return res.json({\n        success: true,\n        isDemo: true,\n        problem: `${concept || \"\354\210\230\355\225\231II\"} \353\213\250\354\233\220\354\235\230 \354\234\240\354\202\254 \354\227\260\354\212\265 \353\254\270\354\240\234\354\236\205\353\213\210\353\213\244. \354\213\244\354\210\230 \354\240\204\354\262\264\354\235\230 \354\247\221\355\225\251\354\227\220\354\204\234 \354\227\260\354\206\215\354\235\270 \355\225\250\354\210\230 g(x)\352\260\200 g\'(x) = 2x - 3 \354\235\264\352\263\240 g(0) = 4 \354\235\274 \353\225\214 g(2)\354\235\230 \352\260\222\354\235\204 \352\265\254\355\225\230\354\213\234\354\230\244.`,\n        options: [\"1\", \"2\", \"3\", \"4\", \"5\"],\n        correctIndex: 3,\n        explanation: \"g(x) = x^2 - 3x + C \354\227\220\354\204\234 g(0)=4 \354\235\264\353\257\200\353\241\234 C=4 \354\236\205\353\213\210\353\213\244. \353\224\260\353\235\274\354\204\234 g(x) = x^2 - 3x + 4 \354\235\264\353\251\260, g(2) = 4 - 6 + 4 = 2 \354\236\205\353\213\210\353\213\244. \354\240\225\353\213\265\354\235\200 4\353\262\210(\352\260\222 2)\354\236\205\353\213\210\353\213\244.\"\n      });\n    }\n\n    const promptText = `\n\353\214\200\355\225\234\353\257\274\352\265\255 \354\210\230\353\212\245 \354\210\230\355\225\231 \354\266\234\354\240\234 \354\234\204\354\233\220\354\235\264\353\235\274\352\263\240 \352\260\200\354\240\225\355\225\230\352\263\240, \353\213\244\354\235\214 \353\213\250\354\233\220\352\263\274 \353\202\234\354\235\264\353\217\204\354\227\220 \353\266\200\355\225\251\355\225\230\353\212\224 \352\260\235\352\264\200\354\213\235 5\354\247\200\354\204\240\353\213\244 \354\234\240\354\202\254 \352\270\260\354\266\234 \354\227\260\354\212\265 \353\254\270\354\240\234\353\245\274 1\352\260\234 \354\203\210\353\241\234 \354\266\234\354\240\234\355\225\230\352\263\240 \352\267\270 \355\222\200\354\235\264\353\245\274 \354\236\221\354\204\261\355\225\264\354\244\230.\n\353\213\250\354\233\220: ${concept || \"\354\210\230\355\225\231I \353\230\220\353\212\224 \354\210\230\355\225\231II\"}\n\353\202\234\354\235\264\353\217\204: ${difficulty || \"\354\244\200\355\202\254\353\237\254\"}\n\n\353\260\230\353\223\234\354\213\234 \353\213\244\354\235\214 JSON \352\267\234\352\262\251\354\235\204 \354\227\204\352\262\251\355\236\210 \354\247\200\354\274\234\354\204\234 \354\210\234\354\210\230 JSON\354\234\274\353\241\234\353\247\214 \353\260\230\355\231\230\355\225\264\354\244\230:\n{\n  \"problem\": \"\354\266\234\354\240\234\353\220\234 \354\210\230\355\225\231 \353\254\270\354\240\234\354\235\230 \354\236\220\354\204\270\355\225\234 \354\204\244\353\252\205 \353\260\217 \352\265\254\355\225\230\353\240\244\353\212\224 \352\262\203\",\n  \"options\": [\"1\353\262\210 \353\263\264\352\270\260\", \"2\353\262\210 \353\263\264\352\270\260\", \"3\353\262\210 \353\263\264\352\270\260\", \"4\353\262\210 \353\263\264\352\270\260\", \"5\353\262\210 \353\263\264\352\270\260\"],\n  \"correctIndex\": \354\240\225\353\213\265 \353\262\210\355\230\270\354\235\230 \354\235\270\353\215\261\354\212\244 (0\353\266\200\355\204\260 4\352\271\214\354\247\200\354\235\230 \354\240\225\354\210\230)\",\n  \"explanation\": \"\355\225\264\353\213\271 \353\254\270\354\240\234\353\245\274 \355\221\270\353\212\224 \353\252\205\354\276\214\355\225\230\352\263\240 \354\203\201\354\204\270\355\225\234 \355\222\200\354\235\264 \352\263\274\354\240\225\"\n}\n`;\n\n    const response = await ai.models.generateContent({\n      model: \"gemini-3.5-flash\",\n      contents: promptText,\n      config: {\n        responseMimeType: \"application/json\",\n      },\n    });\n\n    const parsedData = JSON.parse((response.text || \"{}\").trim());\n    return res.json({ success: true, data: parsedData });\n  } catch (error: any) {\n    console.error(\"\354\234\240\354\202\254 \353\254\270\354\240\234 \354\203\235\354\204\261 \354\230\244\353\245\230:\", error);\n    return res.status(500).json({\n      error: \"\354\234\240\354\202\254 \354\227\260\354\212\265 \353\254\270\354\240\234\353\245\274 \354\203\235\354\204\261\355\225\230\353\212\224 \353\215\260 \354\213\244\355\214\250\355\226\210\354\212\265\353\213\210\353\213\244.\",\n      details: error.message,\n    });\n  }\n});\n\n// Configure Vite middleware in development environment to support HMR and asset serving\nif (process.env.NODE_ENV !== \"production\") {\n  const vite = await createViteServer({\n    server: { middlewareMode: true },\n    appType: \"spa\",\n  });\n  app.use(vite.middlewares);\n} else {\n  const distPath = path.join(process.cwd(), \"dist\");\n  app.use(express.static(distPath));\n  app.get(\"*\", (req, res) => {\n    res.sendFile(path.join(distPath, \"index.html\"));\n  });\n}\n\napp.listen(PORT, \"0.0.0.0\", () => {\n  console.log(`\354\210\230\353\212\245 \354\210\230\355\225\231 \354\210\217\354\270\240 \354\204\234\353\262\204\352\260\200 \354\236\221\353\217\231 \354\244\221\354\236\205\353\213\210\353\213\244: http://localhost:${PORT}`);\n});\n"
    }
