    replacement_infos {
      original_chunk {
        target_content: "          {/* Trigger Action Button */}\n          <button\n            type=\"button\"\n            onClick={generateShorts}\n            disabled={isGenerating}\n            className={`w-full py-4 px-6 rounded-3xl text-sm font-bold shadow-lg flex items-center justify-center gap-2.5 transition-all text-white ${\n              isGenerating\n                ? \"bg-stone-400 cursor-not-allowed\"\n                : \"bg-red-500 hover:bg-red-600 active:scale-[0.98] shadow-red-200\"\n            }`}\n          >\n            {isGenerating ? (\n              <>\n                <RefreshCw className=\"w-5 h-5 animate-spin\" />\n                <span>{loadingStep}</span>\n              </>\n            ) : (\n              <>\n                <Sparkles className=\"w-5 h-5\" />\n                <span>AI \354\210\230\353\212\245 \354\210\230\355\225\231 \354\210\217\354\270\240 \355\222\200\354\235\264 \354\240\234\354\236\221\355\225\230\352\270\260</span>\n              </>\n            )}\n          </button>\n\n          {/* Solution Metadata Board */}\n          {shortsData && (\n            <div className=\"bg-stone-800 text-stone-100 rounded-3xl p-6 shadow-md border border-stone-700 space-y-4\">\n              <div className=\"flex items-center justify-between\">\n                <span className=\"text-xs font-extrabold px-3 py-1 rounded-full bg-yellow-400 text-stone-950 flex items-center gap-1\">\n                  <GraduationCap className=\"w-3.5 h-3.5\" />\n                  \352\260\234\353\205\220 \355\225\264\355\202\271 \354\231\204\353\243\214\n                </span>\n                <span className=\"text-xs text-stone-400 font-mono\">{shortsData.concept}</span>\n              </div>\n              <h3 className=\"text-lg font-bold text-white leading-tight\">{shortsData.title}</h3>\n              <p className=\"text-xs text-stone-300 leading-relaxed bg-stone-900/60 p-3.5 rounded-2xl border border-stone-700 font-mono\">\n                <strong>\355\214\220\353\217\205\353\220\234 \354\233\220\353\263\270 \353\254\270\354\240\234:</strong><br />\n                {shortsData.parsedProblemText}\n              </p>\n              \n              <div className=\"bg-red-500/10 border border-red-500/30 rounded-2xl p-4 flex gap-3\">\n                <div className=\"text-red-400 p-1 bg-red-500/20 rounded-xl self-start\">\n                  <Zap className=\"w-5 h-5\" />\n                </div>\n                <div>\n                  <h4 className=\"text-xs font-bold text-red-300 mb-0.5\">\353\214\200\354\271\230\353\217\231 \354\213\234\355\201\254\353\246\277 \354\240\225\353\263\265 \354\271\230\355\212\270\355\202\244 (Takeaway)</h4>\n                  <p className=\"text-xs text-stone-200 leading-relaxed\">{shortsData.takeaway}</p>\n                </div>\n              </div>\n            </div>\n          )}"
        replacement_content: "          {/* Trigger Action Button */}\n          <button\n            type=\"button\"\n            onClick={generateShorts}\n            disabled={isGenerating}\n            className={`w-full py-4 px-6 rounded-3xl text-sm font-bold shadow-2xl flex items-center justify-center gap-2.5 transition-all text-white cursor-pointer relative overflow-hidden group/gen ${\n              isGenerating\n                ? \"bg-white/10 text-white/40 border border-white/5 cursor-not-allowed\"\n                : \"bg-gradient-to-r from-blue-500 via-indigo-500 to-purple-600 hover:opacity-95 shadow-blue-500/25 shadow-lg active:scale-[0.98]\"\n            }`}\n          >\n            {isGenerating ? (\n              <>\n                <RefreshCw className=\"w-5 h-5 animate-spin text-blue-400\" />\n                <span className=\"font-mono text-xs uppercase tracking-wider\">{loadingStep}</span>\n              </>\n            ) : (\n              <>\n                <Sparkles className=\"w-5 h-5 text-yellow-300 group-hover/gen:animate-pulse\" />\n                <span className=\"tracking-wide\">AI \354\210\230\353\212\245 \354\210\230\355\225\231 \354\210\217\354\270\240 \355\222\200\354\235\264 \354\240\234\354\236\221\355\225\230\352\270\260</span>\n              </>\n            )}\n          </button>\n\n          {/* Solution Metadata Board */}\n          {shortsData && (\n            <div className=\"bg-white/5 border border-white/10 backdrop-blur-xl rounded-3xl p-6 shadow-2xl space-y-4 relative\">\n              <div className=\"absolute inset-0 border border-blue-500/5 rounded-3xl pointer-events-none\"></div>\n              <div className=\"flex items-center justify-between\">\n                <span className=\"text-[10px] font-extrabold px-3 py-1 rounded-full bg-gradient-to-r from-blue-500/30 to-purple-500/30 text-blue-300 border border-blue-500/30 flex items-center gap-1.5 uppercase tracking-wide\">\n                  <GraduationCap className=\"w-3.5 h-3.5\" />\n                  \352\260\234\353\205\220 \355\225\264\355\202\271 \354\231\204\353\243\214\n                </span>\n                <span className=\"text-[11px] text-white/50 font-mono font-semibold\">{shortsData.concept}</span>\n              </div>\n              <h3 className=\"text-base font-bold text-white leading-snug\">{shortsData.title}</h3>\n              <div className=\"text-xs text-white/80 leading-relaxed bg-black/40 p-4 rounded-2xl border border-white/5 font-mono\">\n                <strong className=\"text-blue-400 block mb-1.5 uppercase tracking-wider text-[10px]\">\355\214\220\353\217\205\353\220\234 \354\233\220\353\263\270 \353\254\270\354\240\234:</strong>\n                {shortsData.parsedProblemText}\n              </div>\n              \n              <div className=\"bg-gradient-to-r from-blue-500/10 to-purple-500/10 border border-blue-500/20 rounded-2xl p-4 flex gap-3\">\n                <div className=\"text-blue-400 p-1.5 bg-blue-500/20 rounded-xl self-start border border-blue-500/10\">\n                  <Zap className=\"w-4 h-4 text-blue-300\" />\n                </div>\n                <div>\n                  <h4 className=\"text-xs font-bold text-blue-300 mb-1 uppercase tracking-wider\">\353\214\200\354\271\230\353\217\231 \354\213\234\355\201\254\353\246\277 \354\240\225\353\263\265 \354\271\230\355\212\270\355\202\244 (Takeaway)</h4>\n                  <p className=\"text-xs text-white/70 leading-relaxed\">{shortsData.takeaway}</p>\n                </div>\n              </div>\n            </div>\n          )}"
      }
