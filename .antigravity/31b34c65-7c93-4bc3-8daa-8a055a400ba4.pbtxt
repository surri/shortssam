      original_chunk {
        target_content: "          {/* Section 2: Creator Persona & Style Customization (3D Cards) */}\n          <section className=\"bg-white rounded-3xl p-6 shadow-sm border border-stone-200\">\n            <div className=\"flex items-center justify-between mb-4\">\n              <div className=\"flex items-center gap-2\">\n                <div className=\"bg-red-50 text-red-500 p-1.5 rounded-lg\">\n                  <Sparkles className=\"w-4 h-4\" />\n                </div>\n                <h2 className=\"text-base font-bold text-stone-800\">2\353\213\250\352\263\204. \354\210\230\353\212\245 \352\260\225\354\202\254 \355\216\230\353\245\264\354\206\214\353\202\230 \353\260\217 \353\271\204\354\243\274\354\226\274 \355\205\214\353\247\210</h2>\n              </div>\n              <span className=\"text-[11px] text-stone-400\">\353\214\200\354\202\254 \355\206\244\354\225\244\353\247\244\353\204\210 \354\204\244\354\240\225</span>\n            </div>\n\n            {/* Persona Choices */}\n            <div className=\"mb-5\">\n              <label className=\"block text-xs font-semibold text-stone-500 mb-2.5\">\354\235\274\355\203\200\352\260\225\354\202\254 \355\225\264\355\202\271 \355\231\224\353\262\225</label>\n              <div className=\"grid grid-cols-1 sm:grid-cols-3 gap-3\">\n                <button\n                  type=\"button\"\n                  onClick={() => setPersona(\"star_teacher\")}\n                  className={`p-3.5 rounded-2xl text-left border transition-all flex flex-col gap-1.5 ${\n                    persona === \"star_teacher\"\n                      ? \"border-red-500 bg-red-50/40 text-red-950 shadow-sm\"\n                      : \"border-stone-200 hover:bg-stone-50 text-stone-600\"\n                  }`}\n                >\n                  <div className=\"flex items-center gap-1.5\">\n                    <span className=\"text-base\">\360\237\223\243</span>\n                    <span className=\"text-xs font-extrabold\">\353\214\200\354\271\230\353\217\231 \354\235\274\355\203\200\352\260\225\354\202\254</span>\n                  </div>\n                  <p className=\"text-[10px] text-stone-400 leading-tight\">\354\227\220\353\204\210\354\240\234\355\213\261\355\225\230\352\263\240 \355\231\225\354\213\240\354\227\220 \354\260\254 \354\226\264\354\241\260, \"\353\254\264\354\241\260\352\261\264 \354\266\234\354\240\234\353\220\251\353\213\210\353\213\244!\"</p>\n                </button>\n\n                <button\n                  type=\"button\"\n                  onClick={() => setPersona(\"snu_mentor\")}\n                  className={`p-3.5 rounded-2xl text-left border transition-all flex flex-col gap-1.5 ${\n                    persona === \"snu_mentor\"\n                      ? \"border-red-500 bg-red-50/40 text-red-950 shadow-sm\"\n                      : \"border-stone-200 hover:bg-stone-50 text-stone-600\"\n                  }`}\n                >\n                  <div className=\"flex items-center gap-1.5\">\n                    <span className=\"text-base\">\360\237\222\241</span>\n                    <span className=\"text-xs font-extrabold\">\354\204\234\354\232\270\353\214\200 \354\235\230\353\214\200\354\203\235 \354\204\240\353\260\260</span>\n                  </div>\n                  <p className=\"text-[10px] text-stone-400 leading-tight\">\354\260\250\353\266\204\355\225\230\352\263\240 \353\252\205\354\262\240\355\225\234 \354\240\204\353\236\265, \354\213\234\355\227\230\354\236\245 \353\271\204\353\262\225 \354\240\204\354\210\230</p>\n                </button>\n\n                <button\n                  type=\"button\"\n                  onClick={() => setPersona(\"math_savior\")}\n                  className={`p-3.5 rounded-2xl text-left border transition-all flex flex-col gap-1.5 ${\n                    persona === \"math_savior\"\n                      ? \"border-red-500 bg-red-50/40 text-red-950 shadow-sm\"\n                      : \"border-stone-200 hover:bg-stone-50 text-stone-600\"\n                  }`}\n                >\n                  <div className=\"flex items-center gap-1.5\">\n                    <span className=\"text-base\">\360\237\224\245</span>\n                    <span className=\"text-xs font-extrabold\">\354\210\230\355\217\254\354\236\220 \352\265\254\354\233\220\354\236\220</span>\n                  </div>\n                  <p className=\"text-[10px] text-stone-400 leading-tight\">\354\225\204\354\243\274 \354\211\275\352\263\240 \354\234\240\354\276\214\355\225\234 \353\271\204\354\234\240, \"\354\264\210\353\223\261\355\225\231\354\203\235\353\217\204 \354\235\264\355\225\264 \352\260\200\353\212\245!\"</p>\n                </button>\n              </div>\n            </div>\n\n            {/* Background Theme Choices */}\n            <div>\n              <label className=\"block text-xs font-semibold text-stone-500 mb-2\">\354\210\217\354\270\240 \353\271\204\354\243\274\354\226\274 \355\205\234\355\224\214\353\246\277</label>\n              <div className=\"grid grid-cols-2 sm:grid-cols-4 gap-2.5\">\n                {[\n                  { id: \"blackboard\", label: \"\353\240\210\355\212\270\353\241\234 \353\266\204\355\225\204 \354\271\240\355\214\220\", emoji: \"\360\237\237\242\" },\n                  { id: \"cyberpunk\", label: \"\353\204\244\354\230\250 \354\202\254\354\235\264\353\262\204\355\216\221\355\201\254\", emoji: \"\342\232\241\" },\n                  { id: \"graph\", label: \"\354\210\230\355\225\231 \353\252\250\353\210\210\354\242\205\354\235\264\", emoji: \"\360\237\223\220\" },\n                  { id: \"pastel\", label: \"\352\260\220\354\204\261 \355\214\214\354\212\244\355\205\224 \355\225\221\355\201\254\", emoji: \"\360\237\214\270\" },\n                ].map((t) => (\n                  <button\n                    key={t.id}\n                    type=\"button\"\n                    onClick={() => setBackgroundTheme(t.id)}\n                    className={`p-2.5 rounded-xl border text-xs font-bold text-center transition-all flex items-center justify-center gap-1.5 ${\n                      backgroundTheme === t.id\n                        ? \"border-stone-900 bg-stone-900 text-white shadow-sm\"\n                        : \"border-stone-200 hover:bg-stone-50 text-stone-700\"\n                    }`}\n                  >\n                    <span>{t.emoji}</span>\n                    <span className=\"truncate\">{t.label}</span>\n                  </button>\n                ))}\n              </div>\n            </div>\n          </section>"
        replacement_content: "          {/* Section 2: Creator Persona & Style Customization (3D Cards) */}\n          <section className=\"bg-white/5 border border-white/10 rounded-3xl p-6 backdrop-blur-xl relative shadow-2xl relative\">\n            <div className=\"absolute inset-0 border border-purple-500/10 rounded-3xl pointer-events-none\"></div>\n            <div className=\"flex items-center justify-between mb-4 relative z-10\">\n              <div className=\"flex items-center gap-2\">\n                <div className=\"bg-purple-500/20 text-purple-400 p-1.5 rounded-lg border border-purple-500/20\">\n                  <Sparkles className=\"w-4 h-4\" />\n                </div>\n                <h2 className=\"text-base font-bold text-white font-display\">2\353\213\250\352\263\204. \354\210\230\353\212\245 \352\260\225\354\202\254 \355\216\230\353\245\264\354\206\214\353\202\230 \353\260\217 \353\271\204\354\243\274\354\226\274 \355\205\214\353\247\210</h2>\n              </div>\n              <span className=\"text-[11px] text-white/40 font-mono\">Diction Synthesis</span>\n            </div>\n\n            {/* Persona Choices */}\n            <div className=\"mb-5 relative z-10\">\n              <label className=\"block text-xs font-semibold text-white/50 mb-2.5 tracking-wide\">\354\235\274\355\203\200\352\260\225\354\202\254 \355\225\264\355\202\271 \355\231\224\353\262\225</label>\n              <div className=\"grid grid-cols-1 sm:grid-cols-3 gap-3\">\n                <button\n                  type=\"button\"\n                  onClick={() => setPersona(\"star_teacher\")}\n                  className={`p-3.5 rounded-2xl text-left border transition-all flex flex-col gap-1.5 cursor-pointer ${\n                    persona === \"star_teacher\"\n                      ? \"border-blue-500/50 bg-blue-500/10 text-white shadow-[0_0_15px_rgba(59,130,246,0.1)]\"\n                      : \"border-white/10 bg-white/5 text-white/70 hover:bg-white/10\"\n                  }`}\n                >\n                  <div className=\"flex items-center gap-1.5\">\n                    <span className=\"text-base\">\360\237\223\243</span>\n                    <span className=\"text-xs font-extrabold\">\353\214\200\354\271\230\353\217\231 \354\235\274\355\203\200\352\260\225\354\202\254</span>\n                  </div>\n                  <p className=\"text-[10px] text-white/45 leading-tight\">\354\227\220\353\204\210\354\240\234\355\213\261\355\225\230\352\263\240 \355\231\225\354\213\240\354\227\220 \354\260\254 \354\226\264\354\241\260, \"\353\254\264\354\241\260\352\261\264 \354\266\234\354\240\234\353\220\251\353\213\210\353\213\244!\"</p>\n                </button>\n\n                <button\n                  type=\"button\"\n                  onClick={() => setPersona(\"snu_mentor\")}\n                  className={`p-3.5 rounded-2xl text-left border transition-all flex flex-col gap-1.5 cursor-pointer ${\n                    persona === \"snu_mentor\"\n                      ? \"border-purple-500/50 bg-purple-500/10 text-white shadow-[0_0_15px_rgba(168,85,247,0.1)]\"\n                      : \"border-white/10 bg-white/5 text-white/70 hover:bg-white/10\"\n                  }`}\n                >\n                  <div className=\"flex items-center gap-1.5\">\n                    <span className=\"text-base\">\360\237\222\241</span>\n                    <span className=\"text-xs font-extrabold\">\354\204\234\354\232\270\353\214\200 \354\235\230\353\214\200\354\203\235 \354\204\240\353\260\260</span>\n                  </div>\n                  <p className=\"text-[10px] text-white/45 leading-tight\">\354\260\250\353\266\204\355\225\230\352\263\240 \353\252\205\354\262\240\355\225\234 \354\240\204\353\236\265, \354\213\234\355\227\230\354\236\245 \353\271\204\353\262\225 \354\240\204\354\210\230</p>\n                </button>\n\n                <button\n                  type=\"button\"\n                  onClick={() => setPersona(\"math_savior\")}\n                  className={`p-3.5 rounded-2xl text-left border transition-all flex flex-col gap-1.5 cursor-pointer ${\n                    persona === \"math_savior\"\n                      ? \"border-pink-500/50 bg-pink-500/10 text-white shadow-[0_0_15px_rgba(236,72,153,0.1)]\"\n                      : \"border-white/10 bg-white/5 text-white/70 hover:bg-white/10\"\n                  }`}\n                >\n                  <div className=\"flex items-center gap-1.5\">\n                    <span className=\"text-base\">\360\237\224\245</span>\n                    <span className=\"text-xs font-extrabold\">\354\210\230\355\217\254\354\236\220 \352\265\254\354\233\220\354\236\220</span>\n                  </div>\n                  <p className=\"text-[10px] text-white/45 leading-tight\">\354\225\204\354\243\274 \354\211\275\352\263\240 \354\234\240\354\276\214\355\225\234 \353\271\204\354\234\240, \"\354\264\210\353\223\261\355\225\231\354\203\235\353\217\204 \354\235\264\355\225\264 \352\260\200\353\212\245!\"</p>\n                </button>\n              </div>\n            </div>\n\n            {/* Background Theme Choices */}\n            <div className=\"relative z-10\">\n              <label className=\"block text-xs font-semibold text-white/50 mb-2 tracking-wide\">\354\210\217\354\270\240 \353\271\204\354\243\274\354\226\274 \355\205\234\355\224\214\353\246\277</label>\n              <div className=\"grid grid-cols-2 sm:grid-cols-4 gap-2.5\">\n                {[\n                  { id: \"blackboard\", label: \"\353\240\210\355\212\270\353\241\234 \353\266\204\355\225\204 \354\271\240\355\214\220\", emoji: \"\360\237\237\242\" },\n                  { id: \"cyberpunk\", label: \"\353\204\244\354\230\250 \354\202\254\354\235\264\353\262\204\355\216\221\355\201\254\", emoji: \"\342\232\241\" },\n                  { id: \"graph\", label: \"\354\210\230\355\225\231 \353\252\250\353\210\210\354\242\205\354\235\264\", emoji: \"\360\237\223\220\" },\n 