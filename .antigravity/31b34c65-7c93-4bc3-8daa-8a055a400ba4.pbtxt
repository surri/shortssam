ageChange}\n                      className=\"absolute inset-0 w-full h-full opacity-0 cursor-pointer\"\n                    />\n                    <div className=\"flex flex-col items-center justify-center gap-1.5\">\n                      <div className=\"p-2 bg-white/5 text-blue-400 rounded-xl border border-white/10\">\n                        <Upload className=\"w-4 h-4\" />\n                      </div>\n                      <span className=\"text-xs font-bold text-white\">\353\254\270\354\240\234 \354\212\244\355\201\254\353\246\260\354\203\267 \354\230\254\353\246\254\352\270\260</span>\n                      <span className=\"text-[10px] text-white/40\">\355\201\264\353\246\255\355\225\230\352\261\260\353\202\230 \354\227\254\352\270\260\353\241\234 \353\223\234\353\236\230\352\267\270</span>\n                    </div>\n                  </div>\n                </div>\n\n                {/* Direct Text Editor Box */}\n                <div>\n                  <label className=\"block text-xs font-semibold text-white/50 mb-1.5\">\353\254\270\354\240\234\353\245\274 \355\205\215\354\212\244\355\212\270\353\241\234 \354\247\201\354\240\221 \354\236\205\353\240\245 (\354\204\240\355\203\235)</label>\n                  <textarea\n                    value={directText}\n                    onChange={(e) => {\n                      setDirectText(e.target.value);\n                      setSelectedPreset(\"\"); // Clear presets if custom text is used\n                    }}\n                    placeholder=\"\354\230\210: \354\202\274\354\260\250\355\225\250\354\210\230 f(x)\352\260\200 f\'(x) = 3x^2... f(3)\354\235\230 \352\260\222\354\235\204 \352\265\254\355\225\230\354\213\234\354\230\244.\"\n                    className=\"w-full h-[106px] text-xs p-3 rounded-2xl border border-white/10 focus:outline-none focus:ring-1 focus:ring-blue-500/50 focus:border-blue-500/50 bg-white/5 text-white placeholder-white/30 resize-none font-sans\"\n                  />\n                </div>\n              </div>\n\n              {/* Uploaded Preview State */}\n              {imageBase64 && (\n                <div className=\"bg-white/5 border border-white/10 rounded-2xl p-3.5 flex items-center justify-between gap-4 animate-fade-in\">\n                  <div className=\"flex items-center gap-3\">\n                    <img\n                      src={imageBase64}\n                      alt=\"\354\210\230\355\225\231 \353\254\270\354\240\234 \354\212\244\355\201\254\353\246\260\354\203\267\"\n                      className=\"w-14 h-14 object-cover rounded-xl border border-white/15 shadow-md\"\n                    />\n                    <div>\n                      <div className=\"text-xs font-bold text-white truncate max-w-[180px]\">\354\227\205\353\241\234\353\223\234\353\220\234 \354\235\264\353\257\270\354\247\200 \355\231\234\354\204\261\355\231\224 \354\231\204\353\243\214</div>\n                      <div className=\"text-[10px] text-emerald-400 flex items-center gap-1 mt-0.5\">\n                        <Check className=\"w-3.5 h-3.5\" /> \353\214\200\354\232\251\353\237\211 \352\263\240\353\260\200\353\217\204 \355\214\220\353\217\205 \353\214\200\352\270\260\354\244\221\n                      </div>\n                    </div>\n                  </div>\n                  <button\n                    type=\"button\"\n                    onClick={() => setImageBase64(\"\")}\n                    className=\"text-xs text-white/40 hover:text-red-400 font-semibold px-2.5 py-1 hover:bg-red-500/10 rounded-lg transition-all cursor-pointer\"\n                  >\n                    \354\202\255\354\240\234\n                  </button>\n                </div>\n              )}\n            </div>\n          </section>"
