# ── 로컬(AI Studio) ──
GEMINI_API_KEY=your-aistudio-api-key

# 저장소: local(JSON 파일) | firestore(GCP)
STORAGE=local
# DB_PATH=./data/works.json
# TTS_MODEL=gemini-2.5-flash-preview-tts

# ── 오디오(TTS) 캐시 ──
# 로컬: data/audio/ 파일이 기본. 경로 변경 시:
# AUDIO_PATH=./data/audio
# GCP: 버킷명 설정 시 GCS 사용(미설정 시 인스턴스 로컬 파일 — Cloud Run에선 재시작 시 소실)
# AUDIO_BUCKET=your-project-tts-cache

# ── GCP(현장 @gcplab.me) 전환 시 ──
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=us-central1
# STORAGE=firestore
# AUDIO_BUCKET=your-project-tts-cache
